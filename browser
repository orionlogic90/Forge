    function resetWagerSesi() {
        var currentBalance = bot.stats.currentBal;
        var lossTolerance = (bot.wagerLossTolerancePercent / 100) * currentBalance;
        var sesiTarget = bot.wagerSesiMultiplier * currentBalance;
        
        bot.wagerTotalAccumulated += bot.wagerSesiCounter;
        bot.wagerSesiCounter = 0;
        bot.wagerSesiStartBal = currentBalance;
        bot.wagerSesiProfit = 0;
        
        bot.stats.profit = 0;
        bot.stats.startBal = currentBalance;
        bot.stats.bets = 0;
        bot.stats.wins = 0;
        bot.stats.loss = 0;
        bot.stats.ties = 0;
        
        baccaratRecovery.active = false;
        
        diceInFlight = 0;
        pendingDiceMeta = [];
        isResting = false;
        normalCycleStartTime = 0;
        
        updateWagerDisplay();
        updateStatsDisplay();
        updateRecoveryDisplay();
