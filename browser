    // ==================== RUN LOOP ====================
    async function runLoop() {
        if (!bot.isRunning || bot.isSleeping || bot.isPaused) return;
        
        var currentBalance = bot.stats.currentBal;
        var lossTolerance = (bot.wagerLossTolerancePercent / 100) * bot.wagerSesiStartBal;
        var sesiTarget = bot.wagerSesiMultiplier * currentBalance;
        
        // ==================== BACCARAT TIE RECOVERY ====================
        if (bot.baccaratEnabled && !baccaratRecovery.active) {
            var lossAmount = bot.wagerSesiStartBal - currentBalance;
            var triggerAmount = (bot.baccaratTriggerPct / 100) * bot.wagerSesiStartBal;
            
            if (lossAmount >= triggerAmount) {
                var started = startBaccaratRecovery();
                if (started) {
                    updateWagerDisplay();
                    updateStatsDisplay();
                    updateRecoveryDisplay();
                    setTimeout(runLoop, 100);
                    return;
                }
            }
        }
        
        // ==================== BACCARAT RECOVERY ACTIVE ====================
        if (baccaratRecovery.active) {
            // CEK: Balance >= Sesi Start Balance → EXIT
            if (bot.stats.currentBal >= bot.wagerSesiStartBal) {
                exitBaccaratRecovery();
                updateStatsDisplay();
                updateWagerDisplay();
                updateRecoveryDisplay();
                setTimeout(runLoop, 500);
                return;
            }
            
            // CEK: Balance >= Trigger Balance → EXIT
            if (bot.stats.currentBal >= baccaratRecovery.triggerBalance) {
                exitBaccaratRecovery();
                updateStatsDisplay();
                updateWagerDisplay();
                updateRecoveryDisplay();
                setTimeout(runLoop, 500);
                return;
            }
            
            // ==================== PHASE 1: DUAL BET ====================
            if (baccaratRecovery.phase === 1) {
                var dualBet = getDualBetAmount();
                var totalDualBet = dualBet * 2;
                
                if (totalDualBet > bot.stats.currentBal) {
                    forceStopBaccaratRecovery("Insufficient balance for Dual Bet");
                    updateStatsDisplay();
                    updateWagerDisplay();
                    updateRecoveryDisplay();
                    setTimeout(runLoop, 500);
                    return;
                }
                
                // Bet Player
                var playerResult = await placeBaccaratBet("player", dualBet);
                var playerProcessed = processBaccaratResult(playerResult, "player", dualBet);
                baccaratRecovery.totalBets++;
                
                // Bet Banker
                var bankerResult = await placeBaccaratBet("banker", dualBet);
                var bankerProcessed = processBaccaratResult(bankerResult, "banker", dualBet);
                baccaratRecovery.totalBets++;
                
                var pnl = playerProcessed.pnl + bankerProcessed.pnl;
                var isTie = playerProcessed.tie || bankerProcessed.tie;
                
                // Update total loss
                if (pnl < 0) {
                    baccaratRecovery.totalLoss += Math.abs(pnl);
                }
                
                // Update stats
                if (playerProcessed.result === "win") {
                    baccaratRecovery.wins++;
                } else if (playerProcessed.result === "loss") {
                    baccaratRecovery.losses++;
                } else if (playerProcessed.result === "tie") {
                    baccaratRecovery.ties++;
                }
                
                if (bankerProcessed.result === "win") {
                    baccaratRecovery.wins++;
                } else if (bankerProcessed.result === "loss") {
                    baccaratRecovery.losses++;
                } else if (bankerProcessed.result === "tie") {
                    baccaratRecovery.ties++;
                }
                
                var profitDisplay = pnl >= 0 ? "+" + pnl.toFixed(4) : pnl.toFixed(4);
                logBet(bot.stats.bets, dualBet.toFixed(4), "DUAL", "P/B", profitDisplay);
                
                // CEK TIE
                if (isTie) {
                    baccaratRecovery.counter = 0;
                    sendTelegramMessage("🃏 TIE FOUND! Counter reset to 0");
                    updateRecoveryDisplay();
                    setTimeout(runLoop, bot.baccaratDelayMs);
                    return;
                }
                
                // Increment counter
                baccaratRecovery.counter++;
                
                // CEK: 10x tanpa Tie → Pindah ke Phase 2
                if (baccaratRecovery.counter >= 10) {
                    baccaratRecovery.phase = 2;
                    baccaratRecovery.counter = 0;
                    baccaratRecovery.currentBet = getTieBet();
                    sendTelegramMessage("🃏 10x WITHOUT TIE! Switching to TIE BET\nBet: " + baccaratRecovery.currentBet.toFixed(4) + "\nTotal Loss: " + baccaratRecovery.totalLoss.toFixed(4));
                }
                
                updateStatsDisplay();
                updateWagerDisplay();
                updateRecoveryDisplay();
                
                setTimeout(runLoop, bot.baccaratDelayMs);
                return;
            }
            
            // ==================== PHASE 2: TIE BET ====================
            if (baccaratRecovery.phase === 2) {
                var tieBet = getTieBet();
                baccaratRecovery.currentBet = tieBet;
                
                if (tieBet > bot.stats.currentBal) {
                    forceStopBaccaratRecovery("Insufficient balance for Tie Bet");
                    updateStatsDisplay();
                    updateWagerDisplay();
                    updateRecoveryDisplay();
                    setTimeout(runLoop, 500);
                    return;
                }
                
                // Bet TIE
                var tieResult = await placeBaccaratBet("tie", tieBet);
                var tieProcessed = processBaccaratResult(tieResult, "tie", tieBet);
                baccaratRecovery.totalBets++;
                baccaratRecovery.previousBet = tieBet;
                
                // Update total loss
                if (tieProcessed.pnl < 0) {
                    baccaratRecovery.totalLoss += Math.abs(tieProcessed.pnl);
                }
                
                // Update stats
                if (tieProcessed.result === "win") {
                    baccaratRecovery.wins++;
                } else if (tieProcessed.result === "loss") {
                    baccaratRecovery.losses++;
                } else if (tieProcessed.result === "tie") {
                    baccaratRecovery.ties++;
                }
                
                var profitDisplay = tieProcessed.pnl >= 0 ? "+" + tieProcessed.pnl.toFixed(4) : tieProcessed.pnl.toFixed(4);
                logBet(bot.stats.bets, tieBet.toFixed(4), "TIE", tieProcessed.winner || "?", profitDisplay);
                
                // CEK: TIE WIN → EXIT
                if (tieProcessed.result === "win") {
                    sendTelegramMessage("🃏 TIE BET WON! Exiting recovery\nProfit: " + tieProcessed.pnl.toFixed(4) + "\nBalance: " + bot.stats.currentBal.toFixed(4));
                    exitBaccaratRecovery();
                    updateStatsDisplay();
                    updateWagerDisplay();
                    updateRecoveryDisplay();
                    setTimeout(runLoop, 500);
                    return;
                }
                
                // CEK: Balance >= Trigger → EXIT
                if (bot.stats.currentBal >= baccaratRecovery.triggerBalance) {
                    exitBaccaratRecovery();
                    updateStatsDisplay();
                    updateWagerDisplay();
                    updateRecoveryDisplay();
                    setTimeout(runLoop, 500);
                    return;
                }
                
                // Update bet untuk next
                baccaratRecovery.currentBet = getTieBet();
                
                updateStatsDisplay();
                updateWagerDisplay();
                updateRecoveryDisplay();
                
                setTimeout(runLoop, bot.baccaratDelayMs);
                return;
            }
        }
        
        // ==================== NORMAL MODE (DICE) ====================
        if (shouldStartRest() && !baccaratRecovery.active) {
            startRestPhase();
            setTimeout(runLoop, 200);
            return;
        }
        
        if (isResting) {
            if (shouldEndRest()) {
                endRestPhase();
            }
            setTimeout(runLoop, 200);
            return;
        }
        
        var now = Date.now();
        checkDailyReset();
        updateDailyProfit();
        if (checkDailyLimits()) return;
        if (now - bot.lastTGReport >= TG_CONFIG.reportInterval && bot.stats.bets > 0) {
            bot.lastTGReport = now;
            await sendSessionReport();
        }
        
        if (checkWagerTotalTarget()) return;
        
        try {
            var currentBalance2 = bot.stats.currentBal;
            
            if (currentBalance2 > bot.stats.peakBalance) {
                bot.stats.peakBalance = currentBalance2;
            }
            if (bot.stats.peakBalance > 0) {
                var dd = (bot.stats.peakBalance - currentBalance2) / bot.stats.peakBalance * 100;
                if (dd > bot.stats.maxDrawdownPct) bot.stats.maxDrawdownPct = dd;
            }
            
            if (currentBalance2 <= 0) {
                bot.isRunning = false;
                toggleStartStop(false);
                sendTelegramMessage("🛑 BALANCE ZERO! Bot stopped.");
                return;
            }
            
            var normalBet = computeNormalBet(currentBalance2);
            var nextBet, chanceToUse, betMode = "normal";
            
            var isBurstBet = false;
            if (bot.wagerJitEnabled && bot.burstEveryN > 0 && !baccaratRecovery.active) {
                bot.burstCounter++;
                if (bot.burstCounter >= bot.burstEveryN) {
                    isBurstBet = true;
                    bot.burstCounter = 0;
                }
            }
            
            if (isBurstBet) {
                chanceToUse = getBurstChance();
                nextBet = getBurstBet(currentBalance2);
                betMode = "jit";
            } else {
                chanceToUse = bot.normalChance;
                nextBet = normalBet;
                betMode = "normal";
            }
            updateBurstDisplay();
            
            if (nextBet > bot.worstBet) bot.worstBet = nextBet;
            if (bot.maxBetCap > 0 && nextBet > bot.maxBetCap) nextBet = bot.maxBetCap;
            nextBet = Math.max(nextBet, bot.minBet);
            if (nextBet > currentBalance2) nextBet = currentBalance2;
            if (nextBet < 0.00000001) nextBet = 0.00000001;
            
            if (betMode === "normal" || betMode === "jit") {
                if (diceInFlight < wagerParallelCap) {
                    sendDiceBetFireAndForget(nextBet, chanceToUse, betMode);
                }
                
                if (normalCycleStartTime === 0) {
                    normalCycleStartTime = Date.now();
                }
                
                setTimeout(runLoop, 10);
                return;
            }
            
            setTimeout(runLoop, 10);
            
        } catch (e) {
            setTimeout(runLoop, 1000);
        }
    }
    
    function computeNormalBet(balance) {
        var baseBetPct = bot.baseBetPercent / 100;
        var baseBet = balance * baseBetPct;
        baseBet = Math.max(baseBet, bot.minBet);
        if (bot.maxBetCap > 0 && baseBet > bot.maxBetCap) {
            baseBet = bot.maxBetCap;
        }
        return baseBet;
    }

