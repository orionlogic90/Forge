            var resultEmoji = processed.result === "win" ? "✅" : (processed.result === "tie" ? "🤝" : "❌");
            sendTelegramMessage("🃏 BACCARAT #" + baccaratRecovery.totalBets + "\n" + sideEmoji + " " + side.toUpperCase() + " | " + resultEmoji + " " + processed.result.toUpperCase() + "\nBet: " + betAmount.toFixed(4) + "\nProfit: " + (processed.pnl >= 0 ? '+' : '') + processed.pnl.toFixed(4) + "\nBalance: " + bot.stats.currentBal.toFixed(4) + "\nTarget: " + bot.wagerSesiStartBal.toFixed(4) + "\nNext Bet: " + baccaratRecovery.currentBet.toFixed(4) + "\nSide: " + baccaratRecovery.side.toUpperCase());
            
            updateStatsDisplay();
            updateWagerDisplay();
            
            if (exited) {
                resetVirtualStreaks();
                updateStatsDisplay();
                updateWagerDisplay();
                sendTelegramMessage("✅ BACCARAT RECOVERY COMPLETE\nBalance: " + bot.stats.currentBal.toFixed(4) + "\nTarget: " + bot.wagerSesiStartBal.toFixed(4) + "\nWins: " + baccaratRecovery.wins + " | Losses: " + baccaratRecovery.losses + " | Ties: " + baccaratRecovery.ties + "\nTotal Bets: " + baccaratRecovery.totalBets + "\nReturning to NORMAL mode");
                setTimeout(runLoop, 500);
                return;
            }
            
            setTimeout(runLoop, 500);
            return;
        }
        
        // ==================== NORMAL MODE ====================
        var targetStartBalance = bot.wagerSesiStartBal - lossTolerance;
        if (currentBalance < targetStartBalance && bot.isRecoveryMode) {
