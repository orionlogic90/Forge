        var savedWagered = bot.stats.wagered;
        bot.stats = { profit: 0, wagered: savedWagered, startBal: bot.stats.currentBal, currentBal: bot.stats.currentBal, bets: 0, wins: 0, loss: 0, ties: 0, startTime: null, maxDD: 0, maxBet: 0, maxDrawdownPct: 0, peakBalance: bot.stats.currentBal };
        bot.betTimestamps = [];
        bot.startTime = null;
        bot.isHarvesting = false;
        bot.isRecoveryMode = false;
        baccaratRecovery.active = false;
