        bot.sessionNumber = 1;
        bot.sessionsCompleted = 0;
        bot.sessionStartTime = null;
        harvestingEntries = [];
        initMemory();
        updateBurstDisplay();
        updateHuntTab();
        updateWagerDisplay();
    }

    function resetVirtualStreaks() {
        for (var i = 0; i < VIRTUAL_CHANCES.length; i++) {
            virtualLs[VIRTUAL_CHANCES[i]] = 0;
        }
        readyChances = [];
    }

    // ==================== LOG BET ====================
    function logBet(betNumber, amount, chance, roll, profit) {
        var logBox = document.getElementById("p-logs");
        if (!logBox) return;
        
        var entry = document.createElement("div");
        entry.style.padding = "3px 8px";
        entry.style.fontSize = "10px";
        entry.style.fontFamily = "monospace";
        entry.style.borderBottom = "1px solid #2a3344";
        entry.style.display = "flex";
        entry.style.justifyContent = "space-between";
        entry.style.gap = "8px";
        entry.style.alignItems = "center";
        
        var numSpan = document.createElement("span");
        numSpan.style.color = "#8899aa";
        numSpan.style.minWidth = "35px";
        numSpan.style.fontSize = "9px";
        numSpan.textContent = "#" + betNumber;
        
        var amtSpan = document.createElement("span");
        amtSpan.style.color = "#8899aa";
        amtSpan.style.minWidth = "65px";
        amtSpan.style.fontSize = "9px";
        amtSpan.textContent = amount;
        
        var chnSpan = document.createElement("span");
        chnSpan.style.color = "#f0b90b";
        chnSpan.style.minWidth = "45px";
        chnSpan.style.fontSize = "9px";
        chnSpan.textContent = chance + "%";
        
        var rollSpan = document.createElement("span");
        rollSpan.style.color = "#8899aa";
        rollSpan.style.minWidth = "35px";
        rollSpan.style.fontSize = "9px";
        rollSpan.textContent = roll;
        
        var profitSpan = document.createElement("span");
        profitSpan.style.color = profit.startsWith('+') ? "#00e676" : "#ff5252";
        profitSpan.style.fontWeight = "bold";
        profitSpan.style.minWidth = "65px";
        profitSpan.style.fontSize = "9px";
        profitSpan.style.textAlign = "right";
        profitSpan.textContent = profit;
        
        entry.appendChild(numSpan);
        entry.appendChild(amtSpan);
        entry.appendChild(chnSpan);
        entry.appendChild(rollSpan);
        entry.appendChild(profitSpan);
        
        logBox.insertBefore(entry, logBox.firstChild);
        
        while (logBox.children.length > 20) {
            logBox.removeChild(logBox.lastChild);
        }
    }

    // ==================== WAGER FUNCTIONS ====================
    function resetWagerSesi() {
        var currentBalance = bot.stats.currentBal;
        var lossTolerance = (bot.wagerLossTolerancePercent / 100) * currentBalance;
        var sesiTarget = bot.wagerSesiMultiplier * currentBalance;
        
        bot.wagerTotalAccumulated += bot.wagerSesiCounter;
        bot.wagerSesiCounter = 0;
        bot.wagerSesiStartBal = currentBalance;
        bot.wagerSesiProfit = 0;
        bot.wagerWaitingForTrigger = false;
        bot.recoverySplitCounter = 0;
        
        bot.stats.profit = 0;
        bot.stats.startBal = currentBalance;
        bot.stats.bets = 0;
        bot.stats.wins = 0;
        bot.stats.loss = 0;
        bot.stats.ties = 0;
        
        bot.isRecoveryMode = false;
        bot.isHarvesting = false;
        baccaratRecovery.active = false;
        bot.recovery = null;
        bot.recoveryStep = 0;
        
        bot.isBoosterMode = false;
        bot.boosterStartProfit = 0;
        bot.boosterBetAmount = 0;
        boosterChanceIndex = 0;
        
        diceInFlight = 0;
        pendingDiceMeta = [];
        isResting = false;
        normalCycleStartTime = 0;
        
        updateWagerDisplay();
        updateStatsDisplay();
    }
    
    function checkWagerTotalTarget() {
        if (bot.wagerTotalAccumulated >= bot.wagerTotalTarget) {
            bot.isRunning = false;
            bot.wagerStop = true;
            toggleStartStop(false);
            sendTelegramMessage("✅ TOTAL WAGER TARGET REACHED!\nTotal Wager: " + bot.wagerTotalAccumulated.toFixed(2) + "\nTarget: " + bot.wagerTotalTarget);
            return true;
        }
        return false;
    }
    
    function getBurstChance() {
        var min = bot.burstMinChance || 1;
        var max = bot.burstMaxChance || 98;
        return Math.round((Math.random() * (max - min) + min) * 10) / 10;
    }
    
    function getBurstBet(currentBalance) {
        var totalLoss = Math.abs(bot.stats.startBal - bot.stats.currentBal);
        var burstChance = getBurstChance();
        var payoutMult = 99 / burstChance;
        var profitMult = payoutMult - 1;
        var burstBet;
        
        if (profitMult > 0 && totalLoss > 0) {
            burstBet = (totalLoss / profitMult) * bot.burstMultiplier;
        } else {
            burstBet = currentBalance * 0.01;
        }
        
        var maxBurstBet = currentBalance * 0.10;
        burstBet = Math.min(burstBet, maxBurstBet);
        
        var jitMaxBet = (bot.jitMaxBetPercent / 100) * currentBalance;
        burstBet = Math.min(burstBet, jitMaxBet);
        
        burstBet = Math.max(burstBet, bot.minBet);
        
        if (bot.maxBetCap > 0 && burstBet > bot.maxBetCap) {
            burstBet = bot.maxBetCap;
        }
        
        return burstBet;
    }

    // ==================== BOOSTER MODE ====================
    function checkBoosterCondition() {
        if (bot.isBoosterMode) return true;
        if (baccaratRecovery.active) return false;
        var currentBalance = bot.stats.currentBal;
        var lossTolerance = (bot.wagerLossTolerancePercent / 100) * currentBalance;
        if (!bot.isHarvesting && !bot.isRecoveryMode && bot.stats.profit > lossTolerance) {
            return true;
        }
        return false;
    }

    function startBoosterMode() {
        bot.isBoosterMode = true;
        bot.boosterStartProfit = bot.stats.profit;
        boosterChanceIndex = 0;
        
        var currentBalance = bot.stats.currentBal;
        var lossTolerance = (bot.wagerLossTolerancePercent / 100) * currentBalance;
        var boosterChance = BOOSTER_CHANCES[boosterChanceIndex % BOOSTER_CHANCES.length];
        
        var betAmount = bot.stats.profit + lossTolerance;
        if (betAmount > bot.stats.currentBal) {
            betAmount = bot.stats.currentBal;
        }
        if (betAmount < bot.minBet) {
            betAmount = bot.minBet;
        }
        if (bot.maxBetCap > 0 && betAmount > bot.maxBetCap) {
            betAmount = bot.maxBetCap;
        }
        
        bot.boosterBetAmount = betAmount;
        resetVirtualStreaks();
        
        sendTelegramMessage("🚀 BOOSTER MODE ACTIVATED\nProfit: " + bot.stats.profit.toFixed(4) + "\nLoss Tolerance: " + lossTolerance.toFixed(4) + "\nBet Amount: " + bot.boosterBetAmount.toFixed(4) + " (FIXED)\nChance: " + boosterChance + "% (Rotation " + ((boosterChanceIndex % BOOSTER_CHANCES.length) + 1) + "/" + BOOSTER_CHANCES.length + ")\nExit when profit ≤ -" + lossTolerance.toFixed(4));
        
        updateStatsDisplay();
        updateBurstDisplay();
    }

    function exitBoosterMode() {
        bot.isBoosterMode = false;
        bot.boosterStartProfit = 0;
        bot.boosterBetAmount = 0;
        boosterChanceIndex = 0;
        resetVirtualStreaks();
        
        var currentBalance = bot.stats.currentBal;
        var lossTolerance = (bot.wagerLossTolerancePercent / 100) * currentBalance;
        
        sendTelegramMessage("🛑 BOOSTER MODE EXIT\nProfit: " + bot.stats.profit.toFixed(4) + " ≤ -Loss Tolerance: -" + lossTolerance.toFixed(4) + "\nBalance: " + bot.stats.currentBal.toFixed(4) + "\n🔄 Resetting session...");
        
        resetWagerSesi();
        updateStatsDisplay();
        updateBurstDisplay();
        updateWagerDisplay();
    }

    // ==================== RUN LOOP ====================
    async function runLoop() {
        if (!bot.isRunning || bot.isSleeping || bot.isPaused) return;
        
        var currentBalance = bot.stats.currentBal;
        var lossTolerance = (bot.wagerLossTolerancePercent / 100) * bot.wagerSesiStartBal;
        var sesiTarget = bot.wagerSesiMultiplier * currentBalance;
        var startBalanceForRecovery = bot.wagerSesiStartBal;
        
        // CEK TRIGGER BACCARAT RECOVERY
        if (bot.baccaratEnabled && !baccaratRecovery.active && !bot.isHarvesting && !bot.isRecoveryMode && !bot.isBoosterMode) {
            var lossPct = ((startBalanceForRecovery - currentBalance) / startBalanceForRecovery) * 100;
            if (lossPct >= bot.baccaratTriggerPct) {
                var started = startBaccaratRecovery();
                if (started) {
                    resetVirtualStreaks();
                    updateWagerDisplay();
                    updateStatsDisplay();
                    setTimeout(runLoop, 100);
                    return;
                }
            }
        }
        
        // JIKA BACCARAT RECOVERY AKTIF
        if (baccaratRecovery.active) {
            if (!bot.isDemo) {
                var freshBalance = await fetchCurrentBalance();
                if (freshBalance > 0) {
                    bot.stats.currentBal = freshBalance;
                    bot.stats.profit = bot.stats.currentBal - bot.stats.startBal;
                }
            }
            
            var betAmount = baccaratRecovery.currentBet;
            var side = baccaratRecovery.side;
            
            if (betAmount > bot.stats.currentBal) {
                betAmount = bot.stats.currentBal * 0.5;
                if (betAmount < bot.minBet) {
                    sendTelegramMessage("🛑 INSUFFICIENT BALANCE FOR BACCARAT\nBalance: " + bot.stats.currentBal.toFixed(4) + "\nMin Bet: " + bot.minBet.toFixed(4) + "\nResetting session...");
                    resetWagerSesi();
                    setTimeout(runLoop, 1000);
                    return;
                }
            }
            
            var result = await placeBaccaratBet(side, betAmount);
            var processed = processBaccaratResult(result, side, betAmount);
            
            var profitDisplay = processed.pnl >= 0 ? "+" + processed.pnl.toFixed(4) : processed.pnl.toFixed(4);
            var resultLabel = processed.result === "win" ? "WIN" : (processed.result === "tie" ? "TIE" : "LOSS");
            logBet(bot.stats.bets, betAmount.toFixed(4), "BAC", side.toUpperCase(), profitDisplay);
            
            if (processed.result === "win") {
                bot.stats.wins++;
                bot.lastWinStatus = true;
            } else if (processed.result === "loss") {
                bot.stats.loss++;
                bot.lastWinStatus = false;
            } else {
                bot.stats.ties = (bot.stats.ties || 0) + 1;
            }
            bot.totalWager += betAmount;
            bot.wagerSesiCounter += betAmount;
            bot.wagerSesiProfit = bot.stats.currentBal - bot.wagerSesiStartBal;
            
            var exited = updateBaccaratD_Alembert(processed.result, processed.pnl);
            
