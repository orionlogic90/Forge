    // ==================== VIRTUAL CHANCE FUNCTIONS ====================
    function initVirtualChances() {
        VIRTUAL_CHANCES = [];
        var minC = bot.virtMinChance;
        var maxC = bot.virtMaxChance;
        
        for (var c = minC; c <= maxC; c = c + 0.5) {
            VIRTUAL_CHANCES.push(parseFloat(c.toFixed(2)));
        }
        
        var baseChance = bot.normalChance;
        var exists = false;
        for (var i = 0; i < VIRTUAL_CHANCES.length; i++) {
            if (Math.abs(VIRTUAL_CHANCES[i] - baseChance) < 0.01) {
                exists = true;
                break;
            }
        }
        if (!exists && baseChance <= maxC + 0.1 && baseChance >= minC - 0.1) {
            VIRTUAL_CHANCES.push(baseChance);
        }
        
        VIRTUAL_CHANCES.sort(function(a, b) { return a - b; });
        
        var infoEl = document.getElementById("virt-range-info");
        if (infoEl) {
            infoEl.innerHTML = "Virtual chances: " + minC + "% - " + maxC + "% (" + VIRTUAL_CHANCES.length + " chances)";
        }
    }
    
    function initMemory() {
        if (VIRTUAL_CHANCES.length === 0) initVirtualChances();
        
        for (var i = 0; i < VIRTUAL_CHANCES.length; i++) {
            var c = VIRTUAL_CHANCES[i];
            var key = Math.floor(c).toString();
            
            var thresholdValue = Math.ceil(99.0 / c) * bot.harvestTrigger;
            
            memory[key] = {
                wins: 0,
                loss: 0,
                max_ls: 0,
                ls_now: 0,
                target: Math.ceil(thresholdValue)
            };
            virtualLs[c] = 0;
            thresholds[c] = Math.ceil(thresholdValue);
        }
        readyChances = [];
    }
    
    function updateMemory(chance, win) {
        var key = Math.floor(chance).toString();
        if (!memory[key]) {
            var thresholdValue = Math.ceil(99.0 / chance) * bot.harvestTrigger;
            memory[key] = { wins: 0, loss: 0, max_ls: 0, ls_now: 0, target: Math.ceil(thresholdValue) };
        }
        var mem = memory[key];
        if (win) {
            mem.wins++;
            mem.max_ls = Math.max(mem.max_ls, mem.ls_now);
            mem.ls_now = 0;
        } else {
            mem.loss++;
            mem.ls_now++;
            mem.max_ls = Math.max(mem.max_ls, mem.ls_now);
        }
    }
    
    function virtualCheckWin(roll, chance) {
        var number = 100 - chance;
        return roll > number;
    }
    
    function updateVirtualStreaks(roll) {
        var changed = false;
        
        for (var i = 0; i < VIRTUAL_CHANCES.length; i++) {
            var c = VIRTUAL_CHANCES[i];
            var isWin = virtualCheckWin(roll, c);
            
            if (isWin) {
                virtualLs[c] = 0;
                var idx = readyChances.indexOf(c);
                if (idx > -1) readyChances.splice(idx, 1);
            } else {
                virtualLs[c]++;
                if (virtualLs[c] >= thresholds[c] && readyChances.indexOf(c) === -1) {
                    readyChances.push(c);
                    changed = true;
                }
            }
            updateMemory(c, isWin);
        }
        
        if (changed) {
            readyChances.sort(function(a, b) { return b - a; });
        }
    }
    
    function getBestTriggerChance() {
        if (readyChances.length === 0) return null;
        var best = null;
        var bestStreak = 0;
        for (var i = 0; i < readyChances.length; i++) {
            var c = readyChances[i];
            if (virtualLs[c] > bestStreak) {
                bestStreak = virtualLs[c];
                best = c;
            }
        }
        return best;
    }
    
    function getPayoutMultiplier(chance) {
        return 99.0 / chance;
    }
    
    function getCutLossLimit(chance, batasMultiplier) {
        var payout = 99 / chance;
        var cutloss = batasMultiplier * payout;
        return Math.ceil(cutloss);
    }
    
    function computeNormalBet(balance) {
        var baseBetPct = bot.baseBetPercent / 100;
        var baseBet = balance * baseBetPct;
        baseBet = Math.max(baseBet, bot.minBet);
        if (bot.maxBetCap > 0 && baseBet > bot.maxBetCap) {
            baseBet = bot.maxBetCap;
        }
        return baseBet;
    }
    
    function computeHarvestBet(balance, isAfterRecovery) {
        var harvestBetPct = bot.harvestBetPercent / 100;
        var harvestBet = balance * harvestBetPct;
        harvestBet = Math.max(harvestBet, bot.minBet);
        if (bot.maxBetCap > 0 && harvestBet > bot.maxBetCap) {
            harvestBet = bot.maxBetCap;
        }
        if (harvestBet > balance * 0.5) {
            harvestBet = balance * 0.5;
        }
        return harvestBet;
    }
    
    function computeRecoveryBet(currentBalance, harvestChance, recoveryData) {
        var totalLoss = recoveryData.totalLoss;
        var totalSplits = recoveryData.totalSplits;
        var currentSplit = recoveryData.currentSplit;
        var targetStartBalance = recoveryData.targetStartBalance;
        var betLossInSplit = recoveryData.betLossInSplit || 0;
        
        var totalLossWithBetLoss = totalLoss + betLossInSplit;
        
        var remainingSplits = totalSplits - currentSplit;
        if (remainingSplits <= 0) remainingSplits = 1;
        
        var lossPerSplit = totalLossWithBetLoss / remainingSplits;
        
        var targetBalance = currentBalance + lossPerSplit;
        
        if (targetBalance > targetStartBalance) {
            targetBalance = targetStartBalance;
        }
        
        var maxTarget = currentBalance * 1.5;
        if (targetBalance > maxTarget) {
            targetBalance = maxTarget;
        }
        
        var lossAmount = targetBalance - currentBalance;
        if (lossAmount <= 0) return 0;
        
        var payoutMult = 99.0 / harvestChance;
        var profitMult = payoutMult - 1;
        if (profitMult <= 0) return 0;
        
        var bet = lossAmount / profitMult;
        
        var maxBet = currentBalance * 0.3;
        if (bet > maxBet) {
            bet = maxBet;
        }
        
        bet = Math.max(bet, bot.minBet);
        
        return bet;
    }
    
    // ==================== BACCARAT RECOVERY FUNCTIONS ====================
    function startBaccaratRecovery() {
        var currentBalance = bot.stats.currentBal;
        var lossTolerance = (bot.wagerLossTolerancePercent / 100) * bot.wagerSesiStartBal;
        
        if (currentBalance >= bot.wagerSesiStartBal - lossTolerance) {
            return false;
        }
        
        baccaratRecovery.active = true;
        baccaratRecovery.startBalance = currentBalance;
        baccaratRecovery.baseBet = currentBalance * (bot.baccaratBaseBetPct / 100);
        baccaratRecovery.baseBet = Math.max(baccaratRecovery.baseBet, bot.minBet);
        baccaratRecovery.currentBet = baccaratRecovery.baseBet;
        baccaratRecovery.unit = baccaratRecovery.baseBet;
        baccaratRecovery.side = "player";
        baccaratRecovery.profit = 0;
        baccaratRecovery.consecutiveLoss = 0;
        baccaratRecovery.wins = 0;
        baccaratRecovery.losses = 0;
        baccaratRecovery.ties = 0;
        baccaratRecovery.lastResult = null;
        baccaratRecovery.totalBets = 0;
        
        resetVirtualStreaks();
        
        sendTelegramMessage("🃏 BACCARAT RECOVERY ACTIVATED\nBalance: " + currentBalance.toFixed(4) + "\nTarget: " + bot.wagerSesiStartBal.toFixed(4) + "\nBase Bet: " + baccaratRecovery.baseBet.toFixed(4) + " (" + bot.baccaratBaseBetPct + "%)\nUnit: " + baccaratRecovery.unit.toFixed(4) + "\nStrategy: D'Alembert\nTrend: Follow the loss\nExit when balance >= " + bot.wagerSesiStartBal.toFixed(4));
        
        return true;
    }
    
    function exitBaccaratRecovery() {
        var finalBalance = bot.stats.currentBal;
        var recoveredAmount = finalBalance - baccaratRecovery.startBalance;
        
        bot.stats.profit = bot.stats.currentBal - bot.stats.startBal;
        bot.wagerSesiProfit = bot.stats.currentBal - bot.wagerSesiStartBal;
        
        sendTelegramMessage("✅ BACCARAT RECOVERY SUCCESS\nBalance: " + finalBalance.toFixed(4) + "\nRecovered: " + recoveredAmount.toFixed(4) + "\nTarget: " + bot.wagerSesiStartBal.toFixed(4) + "\nWins: " + baccaratRecovery.wins + " | Losses: " + baccaratRecovery.losses + " | Ties: " + baccaratRecovery.ties + "\nTotal Bets: " + baccaratRecovery.totalBets + "\nReturning to NORMAL mode");
        
        baccaratRecovery.active = false;
        baccaratRecovery.startBalance = 0;
        baccaratRecovery.baseBet = 0;
        baccaratRecovery.currentBet = 0;
        baccaratRecovery.unit = 0;
        baccaratRecovery.profit = 0;
        baccaratRecovery.consecutiveLoss = 0;
        baccaratRecovery.wins = 0;
        baccaratRecovery.losses = 0;
        baccaratRecovery.ties = 0;
        baccaratRecovery.lastResult = null;
        baccaratRecovery.totalBets = 0;
        
        resetVirtualStreaks();
    }
    
    function updateBaccaratD_Alembert(result, pnl) {
        baccaratRecovery.totalBets++;
        baccaratRecovery.profit += pnl;
        
        if (result === "win") {
            baccaratRecovery.wins++;
            baccaratRecovery.consecutiveLoss = 0;
            baccaratRecovery.currentBet = baccaratRecovery.currentBet - baccaratRecovery.unit;
        } else if (result === "loss") {
            baccaratRecovery.losses++;
            baccaratRecovery.consecutiveLoss++;
            baccaratRecovery.currentBet = baccaratRecovery.currentBet + baccaratRecovery.unit;
            baccaratRecovery.side = (baccaratRecovery.side === "player") ? "banker" : "player";
        } else if (result === "tie") {
            baccaratRecovery.ties++;
        }
        
        if (baccaratRecovery.currentBet < baccaratRecovery.baseBet) {
            baccaratRecovery.currentBet = baccaratRecovery.baseBet;
        }
        
        var maxBet = bot.stats.currentBal * 0.1;
        if (baccaratRecovery.currentBet > maxBet) {
            baccaratRecovery.currentBet = maxBet;
        }
        
        if (bot.stats.currentBal >= bot.wagerSesiStartBal) {
            exitBaccaratRecovery();
            return true;
        }
        
        if (bot.stats.currentBal < baccaratRecovery.startBalance * 0.5) {
            sendTelegramMessage("🛑 BACCARAT RECOVERY FORCE STOP\nBalance: " + bot.stats.currentBal.toFixed(4) + "\nLoss: " + (baccaratRecovery.startBalance - bot.stats.currentBal).toFixed(4) + "\nResetting session...");
            exitBaccaratRecovery();
            resetWagerSesi();
            return true;
        }
        
        return false;
    }
    
    async function placeBaccaratBet(side, amount) {
        if (bot.isDemo) {
            var r = Math.random();
            var result, multiplier, resultType;
            
            if (r < 0.4462) {
                result = "player";
                multiplier = 1;
                resultType = "win";
            } else if (r < 0.9047) {
                result = "banker";
                multiplier = 0.95;
                resultType = "win";
            } else {
                result = "tie";
                multiplier = 8;
                resultType = "tie";
            }
            
            var win = resultType === "win" && result === side;
            var tie = resultType === "tie";
            var payout = 0;
            var pnl = 0;
            
            if (win) {
                payout = amount * (side === "banker" ? 0.95 : 1);
                pnl = payout;
            } else if (tie) {
                payout = amount * 8;
                pnl = 0;
            } else {
                payout = 0;
                pnl = -amount;
            }
            
            var oldBalance = bot.stats.currentBal;
            bot.stats.currentBal = oldBalance + pnl;
            if (bot.stats.currentBal < 0) bot.stats.currentBal = 0;
            bot.stats.profit = bot.stats.currentBal - bot.stats.startBal;
            bot.stats.wagered += amount;
            bot.stats.bets++;
            
            return {
                baccaratBet: {
                    amount: amount,
                    payout: payout,
                    state: {
                        result: result,
                        playerCards: [{rank: "A", suit: "H"}, {rank: "K", suit: "D"}],
                        bankerCards: [{rank: "Q", suit: "C"}, {rank: "J", suit: "S"}]
                    }
                },
                _simulated: true,
                _win: win,
                _tie: tie,
                _pnl: pnl,
                _result: result
            };
        }
        
        var payload = {
            currency: bot.selectedCurrency,
            identifier: Math.random().toString(36).slice(2),
            tie: 0,
            player: 0,
            banker: 0
        };
        payload[side] = parseFloat(amount.toFixed(8));
        
        try {
            var response = await fetch(CONFIG.apiUrl.replace('/_api', '') + '/_api/casino/baccarat/bet', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'x-access-token': accessToken,
                    'x-lockdown-token': 's5MNWtjTM5TvCMkAzxov'
                },
                body: JSON.stringify(payload)
            });
            var result = await response.json();
            return result;
        } catch (error) {
            return { errors: [{ message: error.message }] };
        }
    }
    
    function processBaccaratResult(result, side, amount) {
        if (!result || result.errors) {
            return { pnl: 0, result: "error", tie: false };
        }
        
        var betData = result.baccaratBet || {};
        var state = betData.state || {};
        var betResult = state.result || "unknown";
        var payout = betData.payout || 0;
        var pnl = payout - amount;
        
        var win = false;
        var tie = false;
        
        if (betResult === side) {
            win = true;
        } else if (betResult === "tie") {
            tie = true;
            pnl = 0;
        } else {
            win = false;
        }
        
        if (!bot.isDemo) {
            bot.stats.currentBal += pnl;
            if (bot.stats.currentBal < 0) bot.stats.currentBal = 0;
            bot.stats.profit = bot.stats.currentBal - bot.stats.startBal;
            bot.stats.wagered += amount;
            bot.stats.bets++;
        }
        
        return {
            pnl: pnl,
            result: win ? "win" : (tie ? "tie" : "loss"),
            tie: tie,
            winner: betResult,
            cards: {
                player: state.playerCards || [],
                banker: state.bankerCards || []
            }
        };
    }

    // ==================== FIAT RATE ====================
    async function fetchPriceToIDR(coin) {
        var rate = null;
        
        try {
            var cgId = getCoinGeckoId(coin);
            var cgRes = await fetch("https://api.coingecko.com/api/v3/simple/price?ids=" + cgId + "&vs_currencies=idr", { cache: 'no-cache' });
            var cgData = await cgRes.json();
            if (cgData[cgId] && cgData[cgId].idr) {
                rate = cgData[cgId].idr;
                return rate;
            }
        } catch(e) {}
        
        try {
            var coinRes = await fetch("https://api.binance.com/api/v3/ticker/price?symbol=" + coin + "USDT", { cache: 'no-cache' });
            var coinData = await coinRes.json();
            var idrRes = await fetch("https://api.binance.com/api/v3/ticker/price?symbol=USDTIDR", { cache: 'no-cache' });
            var idrData = await idrRes.json();
            if (coinData.price && idrData.price) {
                rate = parseFloat(coinData.price) * parseFloat(idrData.price);
                return rate;
            }
        } catch(e) {}
        
        if (coin === "IDR") {
            rate = 1;
            return rate;
        }
        
        return null;
    }
    
    function getCoinGeckoId(coin) {
        var map = {
            "DOGE": "dogecoin",
            "BTC": "bitcoin",
            "ETH": "ethereum",
            "LTC": "litecoin",
            "SOL": "solana",
            "XRP": "ripple",
            "BNB": "binancecoin",
            "ADA": "cardano",
            "TRX": "tron",
            "USDT": "tether",
            "IDR": "indonesian-rupiah"
        };
        return map[coin] || coin.toLowerCase();
    }
    
    async function fetchCurrentBalance() {
        if (bot.isDemo) return bot.stats.currentBal;
        
        var token = getAuthToken();
        if (!token || token.length < 30) return bot.stats.currentBal;
        
        var query = 'query{user{balances{available{amount currency}}}}';
        try {
            var res = await fetch(CONFIG.apiUrl + '/graphql', {
                method: "POST",
                headers: { "Content-Type": "application/json", "x-access-token": token },
                body: JSON.stringify({ query: query })
            });
            var json = await res.json();
            if (json && json.data && json.data.user) {
                var bals = json.data.user.balances;
                for (var i = 0; i < bals.length; i++) {
                    if (bals[i].available.currency.toLowerCase() === bot.selectedCurrency.toLowerCase()) {
                        var newBalance = parseFloat(bals[i].available.amount);
                        if (!isNaN(newBalance) && newBalance >= 0) {
                            return newBalance;
                        }
                    }
                }
            }
        } catch(e) {}
        return bot.stats.currentBal;
    }

