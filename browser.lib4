                                    bot.recoverySplitCounter = 0;
                                    resetVirtualStreaks();
                                    sendTelegramMessage("✅ RECOVERY SUCCESS #" + bot.harvestCount + "\nBalance: " + bot.stats.currentBal.toFixed(8));
                                    resetWagerSesi();
                                } else {
                                    var nextSplitNumber2 = recovery2.currentSplit + 1;
                                    var nextChance2 = getHuntChanceForSplit(nextSplitNumber2, bot.harvestChance);
                                    var currentLoss2 = bot.wagerSesiStartBal - bot.stats.currentBal;
                                    var excessLoss4 = currentLoss2 - lossTolerance;
                                    if (excessLoss4 < 0) excessLoss4 = 0;
                                    
                                    var remainingSplits2 = bot.recoveryMaxSplits - recovery2.currentSplit;
                                    if (remainingSplits2 <= 0) remainingSplits2 = 1;
                                    
                                    var nextBet3 = computeRecoveryBet(bot.stats.currentBal, nextChance2, {
                                        totalLoss: excessLoss4,
                                        totalSplits: remainingSplits2,
                                        currentSplit: 0,
                                        startBalance: bot.stats.currentBal,
                                        targetStartBalance: recoveryTarget3,
                                        betLossInSplit: 0
                                    });
                                    
                                    if (nextBet3 > 0) {
                                        bot.harvestChance = nextChance2;
                                        bot.harvestBet = nextBet3;
                                        sendTelegramMessage("🔄 RECOVERY SPLIT " + nextSplitNumber2 + "/" + bot.recoveryMaxSplits + " (after cutloss)\nChance: " + nextChance2 + "%\nBet: " + nextBet3.toFixed(8));
                                    }
                                }
                            } else {
                                var currentLoss3 = bot.wagerSesiStartBal - bot.stats.currentBal;
                                var excessLoss5 = currentLoss3 - lossTolerance;
                                if (excessLoss5 < 0) excessLoss5 = 0;
                                
                                var remainingSplits3 = bot.recoveryMaxSplits - recovery2.currentSplit;
                                if (remainingSplits3 <= 0) remainingSplits3 = 1;
                                
                                var nextBet4 = computeRecoveryBet(bot.stats.currentBal, bot.harvestChance, {
                                    totalLoss: excessLoss5,
                                    totalSplits: remainingSplits3,
                                    currentSplit: 0,
                                    startBalance: bot.stats.currentBal,
                                    targetStartBalance: recoveryTarget3,
                                    betLossInSplit: recovery2.betLossInSplit
                                });
                                
                                if (nextBet4 > 0) {
                                    bot.harvestBet = nextBet4;
                                }
                            }
                        }
                    } else if (bot.isHarvesting) {
                        if (win) {
                            var totalProfit5 = bot.stats.currentBal - bot.harvestStartBalance;
                            endHarvestAndAddToHistory('WIN', totalProfit5, true, false);
                            bot.isHarvesting = false;
                            bot.isAfterRecovery = true;
                            resetVirtualStreaks();
                            sendTelegramMessage("✅ HARVEST WIN #" + bot.harvestCount + "\nProfit: " + totalProfit5.toFixed(8) + "\nBalance: " + bot.stats.currentBal.toFixed(8));
                        } else {
                            bot.harvestBet = bot.harvestBet * bot.harvestMultiplier;
                            if (bot.maxBetCap > 0 && bot.harvestBet > bot.maxBetCap) bot.harvestBet = bot.maxBetCap;
                            
                            var batasMultiplier3 = bot.maxCutLossMultiplier || 5;
                            var cutLimit3 = getCutLossLimit(bot.harvestChance, batasMultiplier3);
                            var currentLS = virtualLs[bot.harvestChance];
                            
                            if (currentLS >= cutLimit3) {
                                var totalLoss3 = bot.stats.currentBal - bot.harvestStartBalance;
                                endHarvestAndAddToHistory('CUT LOSS', totalLoss3, false, true);
                                bot.isHarvesting = false;
                                bot.isRecoveryMode = false;
                                bot.recoveryStep = 0;
                                bot.recovery = null;
                                bot.isAfterRecovery = false;
                            }
                        }
                    }
                    
                    if (!bot.isHarvesting && !bot.isRecoveryMode) {
                        if (bot.wagerSesiCounter >= sesiTarget) {
                            resetWagerSesi();
                        }
                    }
                }
                
                updateWagerDisplay();
                updateStatsDisplay();
                
                var currentDelay = bot.isRecoveryMode ? 200 : 100;
                setTimeout(runLoop, currentDelay);
                return;
            }
            
            setTimeout(runLoop, 10);
            
        } catch (e) {
            setTimeout(runLoop, 1000);
        }
    }

    // ==================== UPDATE STATS ====================
    function updateStatsDisplay() {
        var profitPct = bot.stats.startBal > 0 ? (bot.stats.profit / bot.stats.startBal * 100) : 0;
        var dailyProfitPct = bot.dailyStartBalance > 0 ? (bot.dailyProfit / bot.dailyStartBalance * 100) : 0;
        var totalDecided = bot.stats.wins + bot.stats.loss;
        var winRate = totalDecided > 0 ? (bot.stats.wins / totalDecided * 100) : 0;
        var runTime = getDuration();
        var rakeback = bot.stats.wagered * 0.00098;
        var betSpeed = getBetSpeed();
        var profitInIdr = bot.stats.profit * bot.fiatRates.idr;
        var wageredInIdr = bot.stats.wagered * bot.fiatRates.idr;
        var balanceInIdr = bot.stats.currentBal * bot.fiatRates.idr;
        var maxDDPct = bot.stats.maxDrawdownPct;
        var maxBetPct = bot.stats.startBal > 0 ? (bot.stats.maxBet / bot.stats.startBal * 100) : 0;
        var currentBalance = bot.stats.currentBal;
        var lossTolerance = (bot.wagerLossTolerancePercent / 100) * currentBalance;
        var sesiTarget = bot.wagerSesiMultiplier * currentBalance;
        
        var wagerProgress = bot.wagerTotalTarget > 0 ? (bot.wagerTotalAccumulated / bot.wagerTotalTarget) * 100 : 0;
        if (wagerProgress > 100) wagerProgress = 100;
        var wagerProgressEl = document.getElementById("st-wager-progress");
        if (wagerProgressEl) wagerProgressEl.textContent = wagerProgress.toFixed(1) + "%";
        var wagerProgressBar = document.getElementById("st-wager-progress-bar");
        if (wagerProgressBar) wagerProgressBar.style.width = wagerProgress + "%";
        
        var wageredEl = document.getElementById("st-wagered");
        if (wageredEl) wageredEl.textContent = bot.wagerTotalAccumulated.toFixed(2);
        var wagerTotalEl = document.getElementById("st-wager-total");
        if (wagerTotalEl) wagerTotalEl.textContent = bot.wagerTotalTarget;
        var sesiCounterEl = document.getElementById("st-sesi-counter");
        if (sesiCounterEl) sesiCounterEl.textContent = bot.wagerSesiCounter.toFixed(2);
        var sesiTargetEl = document.getElementById("st-sesi-target");
        if (sesiTargetEl) sesiTargetEl.textContent = sesiTarget.toFixed(2);
        var sesiLossEl = document.getElementById("st-sesi-loss");
        if (sesiLossEl) sesiLossEl.textContent = bot.wagerSesiProfit.toFixed(4);
        var lossToleranceEl = document.getElementById("st-loss-tolerance");
        if (lossToleranceEl) lossToleranceEl.textContent = lossTolerance.toFixed(4);
        var sesiProfitEl = document.getElementById("st-sesi-profit");
        if (sesiProfitEl) sesiProfitEl.textContent = bot.wagerSesiProfit.toFixed(4);
        
        var status;
        if (baccaratRecovery.active) {
            status = "🃏 BAC " + baccaratRecovery.side.toUpperCase() + " | Bet: " + baccaratRecovery.currentBet.toFixed(4) + " | Target: " + bot.wagerSesiStartBal.toFixed(4);
        } else if (bot.isBoosterMode) {
            status = "🚀 BOOSTER " + BOOSTER_CHANCES[boosterChanceIndex % BOOSTER_CHANCES.length] + "%";
        } else if (bot.isHarvesting) {
            status = bot.isRecoveryMode ? "🔄 R" + bot.harvestChance + "%" : "🌾 H" + bot.harvestChance + "%";
        } else {
            status = "⚡ " + bot.normalChance + "%";
        }
        
        var dailyStatus = (bot.dailyProfit >= 0 ? '+' : '') + bot.dailyProfit.toFixed(8) + " (" + (dailyProfitPct >= 0 ? '+' : '') + dailyProfitPct.toFixed(2) + "%)";
        var timerDisplay = bot.isResetting ? "⏰ " + bot.resetCountdownRemaining + "s" : "--";
        
        var sessionTargetAmount = (bot.stats.startBal * bot.targetPct / 100);
        
        var elements = {
            "st-user": bot.stakeUser,
            "st-running-time": runTime,
            "st-balance": bot.stats.currentBal.toFixed(2) + " " + bot.selectedCurrency.toUpperCase(),
            "st-balance-fiat": shortFiat(balanceInIdr),
            "st-session-num": bot.sessionNumber,
            "st-sessions-done": bot.sessionsCompleted,
            "st-profit": (bot.stats.profit >= 0 ? '+' : '') + bot.stats.profit.toFixed(2) + " (" + (profitPct >= 0 ? '+' : '') + profitPct.toFixed(2) + "%)",
            "st-profit-fiat": shortFiat(profitInIdr),
            "st-daily": dailyStatus,
            "st-wagered-2": bot.stats.wagered.toFixed(2),
            "st-rakeback": "+" + rakeback.toFixed(2),
            "st-bets": bot.stats.bets + " | WR " + winRate.toFixed(0) + "%",
            "st-speed": betSpeed.toFixed(1) + "b/s",
            "st-maxdd": maxDDPct.toFixed(1) + "%",
            "st-chance": status,
            "st-timer": timerDisplay,
            "st-rate": "1 " + bot.selectedCurrency.toUpperCase() + " = " + bot.fiatRates.idr.toFixed(2) + " IDR",
            "st-worst-bet": bot.worstBet > 0 ? bot.worstBet.toFixed(2) + " " + bot.selectedCurrency.toUpperCase() : "-",
            "st-split-progress": bot.recovery && bot.recovery.active ? (bot.recovery.currentSplit + 1) + "/" + bot.recovery.totalSplits : "—",
            "st-cutloss-count": bot.recovery && bot.recovery.active ? (bot.recovery.cutLossCount || 0) : "0",
            "st-loss-per-split": bot.recovery && bot.recovery.active && bot.recovery.lossPerSplit ? bot.recovery.lossPerSplit.toFixed(8) : "0"
        };
        
        for (var id in elements) {
            var el = document.getElementById(id);
            if (el) el.textContent = elements[id];
        }
        
        var runningTime2 = document.getElementById("st-running-time-2");
        if (runningTime2) runningTime2.textContent = runTime;
        
        var profitEl = document.getElementById("st-profit");
        if (profitEl) profitEl.style.color = bot.stats.profit >= 0 ? "#00e676" : "#ff5252";
        var profitFiatEl = document.getElementById("st-profit-fiat");
        if (profitFiatEl) profitFiatEl.style.color = bot.stats.profit >= 0 ? "#00e676" : "#ff5252";
        var dailyEl = document.getElementById("st-daily");
        if (dailyEl) dailyEl.style.color = bot.dailyProfit >= 0 ? "#00e676" : "#ff5252";
        
        updateBurstDisplay();
        updateHuntTab();
        updateWagerDisplay();
    }
    
    function shortFiat(idr) {
        var abs = Math.abs(idr);
        var sign = idr < 0 ? "-" : "";
        if (abs >= 1000000) return sign + "Rp" + (abs/1000000).toFixed(1) + "M";
        if (abs >= 1000) return sign + "Rp" + (abs/1000).toFixed(1) + "K";
        return sign + "Rp" + abs.toFixed(0);
    }
    
    function resetSession() {
        if (bot.isRunning) { return; }
        fullReset();
    }

    function toggleMinimize() {
        bot.minimized = !bot.minimized;
        var body = document.getElementById("bot-body");
        var btn = document.getElementById("btn-minimize");
        if (bot.minimized) { if (body) body.style.display = "none"; if (btn) btn.textContent = "▼"; }
        else { if (body) body.style.display = "block"; if (btn) btn.textContent = "▲"; }
    }
    
    function toggleDarkMode() {
        bot.darkMode = !bot.darkMode;
        var root = document.getElementById("BotConsole");
        if (!root) return;
        if (bot.darkMode) {
            root.style.setProperty('--bg', '#0d0f14');
            root.style.setProperty('--bg-block', '#151a22');
            root.style.setProperty('--text', '#e8edf2');
            root.style.setProperty('--text-light', '#8899aa');
            root.style.setProperty('--border', '#2a3344');
            root.style.setProperty('--log-bg', '#0d0f14');
            root.style.setProperty('--accent', '#f0b90b');
            root.style.setProperty('--success', '#00e676');
            root.style.setProperty('--danger', '#ff5252');
        } else {
            root.style.setProperty('--bg', '#f5f6fa');
            root.style.setProperty('--bg-block', '#ffffff');
            root.style.setProperty('--text', '#1a1a2e');
            root.style.setProperty('--text-light', '#6b7280');
            root.style.setProperty('--border', '#e5e7eb');
            root.style.setProperty('--log-bg', '#f5f6fa');
            root.style.setProperty('--accent', '#f0b90b');
            root.style.setProperty('--success', '#00a86b');
            root.style.setProperty('--danger', '#ff4757');
        }
        renderHarvestingEntries();
        updateHuntTab();
        updateWagerDisplay();
    }

    var pos1 = 0, pos2 = 0, pos3 = 0, pos4 = 0;
    function dragMouseDown(e) {
        if (e.target.closest && (e.target.closest('button') || e.target.closest('input') || e.target.closest('select'))) return;
        e = e || window.event;
        e.preventDefault();
        pos3 = e.clientX;
        pos4 = e.clientY;
        document.onmouseup = closeDragElement;
        document.onmousemove = elementDrag;
    }
    function elementDrag(e) {
        var elmnt = document.getElementById("BotConsole");
        e = e || window.event;
        e.preventDefault();
        pos1 = pos3 - e.clientX;
        pos2 = pos4 - e.clientY;
        pos3 = e.clientX;
        pos4 = e.clientY;
        var newTop = elmnt.offsetTop - pos2;
        var newLeft = elmnt.offsetLeft - pos1;
        var maxLeft = window.innerWidth - elmnt.offsetWidth;
        var maxTop = window.innerHeight - elmnt.offsetHeight;
        if (newLeft < 0) newLeft = 0;
        if (newTop < 0) newTop = 0;
        if (newLeft > maxLeft) newLeft = maxLeft;
        if (newTop > maxTop) newTop = maxTop;
        elmnt.style.top = newTop + "px";
        elmnt.style.left = newLeft + "px";
        elmnt.style.right = "auto";
    }
    function closeDragElement() { document.onmouseup = null; document.onmousemove = null; }

    window.openTab = function(tabName) {
        var tabs = document.querySelectorAll('.tab-content');
        for (var i = 0; i < tabs.length; i++) tabs[i].classList.remove('active');
        var target = document.getElementById('tab-' + tabName);
        if (target) target.classList.add('active');
        var btns = document.querySelectorAll('.tab-btn');
        for (var j = 0; j < btns.length; j++) btns[j].classList.remove('active');
        if (event && event.currentTarget) event.currentTarget.classList.add('active');
        if (tabName === 'history') {
            setTimeout(function() { renderHarvestingEntries(); }, 200);
        }
        if (tabName === 'hunt') {
            setTimeout(function() { updateHuntTab(); }, 100);
        }
    };

    // ==================== SAFE GET ELEMENT VALUE ====================
    function safeGetValue(id, defaultValue) {
        var el = document.getElementById(id);
        if (el) return el.value;
        return defaultValue;
    }
    
    function safeGetInt(id, defaultValue) {
        var val = parseInt(safeGetValue(id, defaultValue));
        return isNaN(val) ? defaultValue : val;
    }
    
    function safeGetFloat(id, defaultValue) {
        var val = parseFloat(safeGetValue(id, defaultValue));
        return isNaN(val) ? defaultValue : val;
    }

    // ==================== CREATE UI ====================
    function createUI() {
        if (document.getElementById("BotConsole")) document.getElementById("BotConsole").remove();
        
        var style = document.createElement("style");
        style.innerHTML = `
            :root { 
                --bg: #0d0f14; 
                --bg-block: #151a22; 
                --text: #e8edf2; 
                --text-light: #8899aa; 
                --border: #2a3344; 
                --log-bg: #0d0f14; 
                --accent: #f0b90b; 
                --success: #00e676; 
                --danger: #ff5252; 
                --info: #448aff;
            }
            #BotConsole { 
                position: fixed; 
                top: 10px; 
                left: 10px; 
                right: 10px; 
                width: auto; 
                max-width: 600px; 
                margin: 0 auto; 
                background: var(--bg); 
                border-radius: 16px; 
                font-family: 'Segoe UI', Consolas, monospace; 
                font-size: 12px; 
                box-shadow: 0 8px 40px rgba(0,0,0,0.6); 
                border: 1px solid var(--border); 
                z-index: 99999; 
                overflow: hidden; 
                color: var(--text);
                transition: all 0.3s ease;
            }
            @media (min-width: 768px) { 
                #BotConsole { top: 20px; right: 20px; left: auto; width: 600px; } 
            }
            .bot-header { 
                background: linear-gradient(135deg, #1a1a2e, #0d0f14); 
                padding: 10px 16px; 
                cursor: move; 
                display: flex; 
                justify-content: space-between; 
                align-items: center; 
                color: var(--text);
                border-bottom: 2px solid var(--accent);
                touch-action: none; 
            }
            .bot-header .title { 
                font-weight: 700; 
                font-size: 15px; 
                color: var(--accent);
                letter-spacing: 0.5px;
            }
            .bot-header .subtitle {
                font-size: 9px;
                color: var(--text-light);
                margin-left: 8px;
                font-weight: 400;
                letter-spacing: 1px;
            }
            .header-btns { display: flex; gap: 6px; }
            .header-btns button { 
                background: rgba(255,255,255,0.05); 
                border: 1px solid var(--border); 
                color: var(--text-light); 
                width: 30px; 
                height: 30px; 
                border-radius: 8px; 
                cursor: pointer; 
                font-size: 14px;
                transition: 0.3s;
            }
            .header-btns button:hover {
                background: var(--accent);
                color: #0d0f14;
                border-color: var(--accent);
            }
            .time-running { 
                background: rgba(240,185,11,0.15); 
                padding: 3px 12px; 
                border-radius: 20px; 
                font-size: 10px; 
                color: var(--accent); 
                font-weight: 600;
                border: 1px solid rgba(240,185,11,0.2);
            }
            .tab-bar { 
                display: flex; 
                padding: 0 12px; 
                gap: 2px; 
                border-bottom: 1px solid var(--border); 
                background: var(--bg); 
                overflow-x: auto; 
                -webkit-overflow-scrolling: touch; 
            }
            .tab-btn { 
                padding: 10px 14px; 
                background: transparent; 
                border: none; 
                color: var(--text-light); 
                font-size: 10px; 
                font-weight: 600; 
                cursor: pointer; 
                border-bottom: 2px solid transparent; 
                white-space: nowrap;
                transition: 0.3s;
                font-family: 'Segoe UI', sans-serif;
                letter-spacing: 0.3px;
            }
            .tab-btn:hover { color: var(--text); }
            .tab-btn.active { 
                color: var(--accent); 
                border-bottom-color: var(--accent); 
            }
            .tab-content { 
                display: none; 
                padding: 12px; 
                max-height: 70vh; 
                overflow-y: auto; 
                -webkit-overflow-scrolling: touch; 
            }
            .tab-content.active { display: block; }
            
            .controls-row { 
                display: flex; 
                flex-wrap: wrap; 
                gap: 8px; 
                margin-bottom: 12px; 
                background: var(--bg-block); 
                padding: 10px; 
                border-radius: 12px; 
                border: 1px solid var(--border); 
            }
            .btn-group { 
                display: flex; 
                gap: 6px; 
                flex: 1; 
                min-width: 140px; 
            }
            .btn-group .btn { 
                padding: 8px 14px; 
                border: none; 
                border-radius: 8px; 
                font-weight: 700; 
                font-size: 10px; 
                cursor: pointer; 
                min-height: 36px; 
                flex: 1;
                font-family: 'Segoe UI', sans-serif;
                transition: 0.3s;
                letter-spacing: 0.3px;
            }
            .btn-group .btn:hover { transform: scale(1.02); }
            .btn-group .btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }
            .btn-start { background: var(--success); color: #0d0f14; }
            .btn-stop { background: var(--danger); color: #fff; }
            .btn-pause { background: var(--text-light); color: #0d0f14; }
            .btn-reset { background: var(--border); color: var(--text); }
            .btn-login { background: var(--accent); color: #0d0f14; padding: 8px 16px; border: none; border-radius: 8px; font-weight: 700; font-size: 10px; cursor: pointer; min-height: 36px; transition: 0.3s; }
            .btn-login:hover { transform: scale(1.02); }
            .btn-refresh { background: var(--border); color: var(--text); padding: 8px 16px; border: none; border-radius: 8px; font-weight: 700; font-size: 10px; cursor: pointer; min-height: 36px; transition: 0.3s; }
            .btn-refresh:hover { background: var(--accent); color: #0d0f14; }
            
            select, input { 
                background: var(--bg); 
                border: 1px solid var(--border); 
                padding: 6px 10px; 
                border-radius: 8px; 
                font-size: 10px; 
                font-family: monospace; 
                color: var(--text);
                transition: 0.3s;
            }
            select:focus, input:focus {
                border-color: var(--accent);
                outline: none;
            }
            select { min-width: 80px; }
            
            .stats-block { 
                background: var(--bg-block); 
                border-radius: 12px; 
                padding: 10px 12px; 
                margin-bottom: 10px; 
                border: 1px solid var(--border); 
                font-size: 10px; 
                line-height: 1.6; 
            }
            .stats-block .line { 
                display: flex; 
                justify-content: space-between; 
                padding: 3px 0; 
                flex-wrap: wrap; 
                gap: 4px; 
                border-bottom: 1px solid rgba(42,51,68,0.2);
            }
            .stats-block .line:last-child { border-bottom: none; }
            .stats-block .label { color: var(--text-light); font-size: 9px; }
            .stats-block .value { 
                font-weight: 600; 
                text-align: right; 
                color: var(--accent); 
                font-size: 10px; 
                word-break: break-word; 
                max-width: 60%; 
            }
            .stats-block .value-sub { font-size: 8px; color: var(--text-light); text-align: right; }
            .stats-block .divider { border-top: 1px solid var(--border); margin: 6px 0; }
            
            .progress-bar { background: var(--border); border-radius: 4px; margin: 4px 0; height: 6px; overflow: hidden; }
            .progress-fill { background: var(--accent); height: 6px; border-radius: 4px; transition: width 0.5s; }
            
            .logs-container { 
                background: var(--log-bg); 
                border-radius: 12px; 
                height: 300px; 
                overflow-y: auto; 
                padding: 6px; 
                font-size: 9px; 
                border: 1px solid var(--border); 
                -webkit-overflow-scrolling: touch; 
                font-family: monospace; 
            }
            .logs-container::-webkit-scrollbar { width: 3px; }
            .logs-container::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
            
            .token-row { display: flex; gap: 8px; margin-bottom: 10px; flex-wrap: wrap; }
            .token-row input { flex: 1; min-width: 120px; }
            
            .toggle-row { 
                display: flex; 
                justify-content: space-between; 
                align-items: center; 
                background: var(--bg-block); 
                padding: 8px 12px; 
                border-radius: 12px; 
                margin-bottom: 10px; 
                flex-wrap: wrap; 
                gap: 8px; 
                border: 1px solid var(--border);
            }
            .md-switch { position: relative; width: 44px; height: 22px; }
            .md-switch input { opacity: 0; width: 0; height: 0; }
            .md-slider { 
                position: absolute; 
                cursor: pointer; 
                top: 0; left: 0; right: 0; bottom: 0; 
                background: var(--border); 
                border-radius: 22px; 
                transition: 0.3s;
            }
            .md-slider:before { 
                position: absolute; 
                content: ""; 
                height: 16px; 
                width: 16px; 
                left: 3px; 
                bottom: 3px; 
                background: white; 
                border-radius: 50%; 
                transition: 0.3s; 
            }
            input:checked + .md-slider { background: var(--accent); }
            input:checked + .md-slider:before { transform: translateX(22px); }
            
            .md-field { margin-bottom: 6px; }
            .md-field label { display: block; font-size: 9px; font-weight: 500; margin-bottom: 2px; color: var(--text-light); }
            .md-field input, .md-field select { width: 100%; padding: 5px 8px; font-size: 10px; }
            
            .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
            @media (max-width: 480px) { 
                .grid-2 { grid-template-columns: 1fr; } 
                .stats-block .value { max-width: 70%; font-size: 9px; } 
                .btn-group button { flex: 1; } 
            }
            
            .status-inline { display: flex; align-items: center; gap: 8px; font-size: 10px; margin-bottom: 8px; padding: 6px 10px; background: var(--bg-block); border-radius: 8px; border: 1px solid var(--border); }
            .dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; transition: 0.3s; }
            
            .harvesting-panel { 
                background: var(--bg-block); 
                border-radius: 12px; 
                border: 1px solid var(--border); 
                margin-top: 10px; 
                overflow: hidden; 
            }
            .harvesting-header { 
                background: var(--accent); 
                color: #0d0f14; 
                padding: 8px 12px; 
                font-size: 10px; 
                font-weight: 700; 
                display: flex; 
                justify-content: space-between; 
                align-items: center; 
            }
            .harvesting-list { max-height: 400px; overflow-y: auto; padding: 4px; }
            .harvesting-list::-webkit-scrollbar { width: 3px; }
            .harvesting-list::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
            
            .hunt-table { max-height: 400px; overflow-y: auto; font-size: 10px; }
            .hunt-table::-webkit-scrollbar { width: 3px; }
            .hunt-table::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
            
            .hunt-stats { 
                display: flex; 
                justify-content: space-between; 
                flex-wrap: wrap; 
                gap: 8px; 
                padding: 8px 12px; 
                background: var(--bg); 
                border-radius: 8px; 
                margin-top: 8px; 
                font-size: 9px; 
                border: 1px solid var(--border);
            }
            
            .stats-grid {
                display: grid;
                grid-template-columns: 1fr 1fr 1fr 1fr;
                gap: 6px;
                margin-bottom: 8px;
            }
            .stats-grid .stat-card {
                background: var(--bg);
                border-radius: 8px;
                padding: 6px 8px;
                border: 1px solid var(--border);
                text-align: center;
            }
            .stats-grid .stat-card .stat-label {
                font-size: 7px;
                color: var(--text-light);
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }
            .stats-grid .stat-card .stat-value {
                font-size: 12px;
                font-weight: 700;
                color: var(--text);
                margin-top: 2px;
            }
            .stats-grid .stat-card .stat-value.gold { color: var(--accent); }
            .stats-grid .stat-card .stat-value.green { color: var(--success); }
            .stats-grid .stat-card .stat-value.red { color: var(--danger); }
            @media (max-width: 500px) {
                .stats-grid { grid-template-columns: 1fr 1fr; }
            }
            
            .wager-progress-box {
                background: var(--bg);
                border-radius: 8px;
                padding: 8px 12px;
                border: 1px solid var(--border);
                margin-bottom: 8px;
            }
            .wager-progress-box .wager-row {
                display: flex;
                justify-content: space-between;
                flex-wrap: wrap;
                gap: 4px;
                font-size: 9px;
                padding: 2px 0;
            }
            
            ::-webkit-scrollbar { width: 3px; }
            ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
            ::-webkit-scrollbar-track { background: transparent; }
        `;
        
        if (document.head) {
            document.head.appendChild(style);
        } else if (document.body) {
            document.body.appendChild(style);
        }
        
        var html = `
        <div id="BotConsole">
            <div class="bot-header" id="botHeader">
                <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;">
                    <span class="title">⭐ ORION ASCEND v4.0</span>
                    <span class="subtitle">"Fire & Forget Wager Farming"</span>
                    <span class="time-running" id="st-running-time">0s</span>
                </div>
                <div class="header-btns">
                    <button id="btn-theme">🌓</button>
                    <button id="btn-minimize">▲</button>
                </div>
            </div>
            <div id="bot-body">
                <div class="tab-bar">
                    <button class="tab-btn active" onclick="openTab.call(this,'dashboard')">📊 DASHBOARD</button>
                    <button class="tab-btn" onclick="openTab.call(this,'settings')">⚙️ SETTINGS</button>
                    <button class="tab-btn" onclick="openTab.call(this,'hunt')">🎯 HUNT</button>
                    <button class="tab-btn" onclick="openTab.call(this,'history')">📋 HISTORY</button>
                </div>
                
                <!-- TAB DASHBOARD -->
                <div id="tab-dashboard" class="tab-content active">
                    <div class="token-row">
                        <input type="password" id="p-token" placeholder="API Token">
                        <button id="p-login" class="btn-login">LOGIN</button>
                        <button id="p-refresh" class="btn-refresh">⟳</button>
                    </div>
                    <div class="toggle-row">
                        <span style="font-size:10px;">⚡ ORION MODE</span>
                        <label class="md-switch"><input type="checkbox" id="p-demo-toggle"><span class="md-slider"></span></label>
                        <span style="font-size:9px;color:var(--text-light);">💰 ORION BALANCE:</span>
                        <input type="number" id="p-dirty-bal" value="50" step="0.1" style="width:70px;padding:4px 6px;font-size:9px;">
                    </div>
                    <div class="controls-row">
                        <div class="btn-group">
                            <button id="p-start" class="btn btn-start">START</button>
                            <button id="p-pause" class="btn btn-pause" disabled>PAUSE</button>
                            <button id="p-stop" class="btn btn-stop" disabled>STOP</button>
                            <button id="p-reset" class="btn btn-reset">RESET</button>
                        </div>
                        <select id="p-currency"></select>
                    </div>
                    <div class="status-inline">
                        <span class="dot" id="statusDot" style="background:#ff5252;"></span>
                        <span id="botStatus" style="font-weight:600;">STOP</span>
                        <span style="color:var(--text-light);margin-left:auto;">⏱️ <span id="st-running-time-2">0s</span></span>
                    </div>
                    
                    <!-- WAGER PROGRESS -->
                    <div class="wager-progress-box">
                        <div style="display:flex;justify-content:space-between;font-size:9px;font-weight:600;color:var(--accent);margin-bottom:4px;">
                            <span>📊 TOTAL WAGER PROGRESS</span>
                            <span id="st-wager-progress">0%</span>
                        </div>
                        <div class="progress-bar" style="height:8px;">
                            <div class="progress-fill" id="st-wager-progress-bar" style="width:0%;"></div>
                        </div>
                        <div class="wager-row" style="margin-top:4px;">
                            <span>💰 <span id="st-wagered">0</span> / <span id="st-wager-total">10000</span></span>
                            <span>📋 Sesi: <span id="st-sesi-counter">0</span> / <span id="st-sesi-target">0</span></span>
                            <span>📉 Loss: <span id="st-sesi-loss">0</span> / <span id="st-loss-tolerance">0</span></span>
                            <span style="color:var(--success);">📈 Sesi Profit: <span id="st-sesi-profit">0</span></span>
                        </div>
                    </div>
                    
                    <!-- STATS GRID -->
                    <div class="stats-grid">
                        <div class="stat-card">
                            <div class="stat-label">Balance</div>
                            <div class="stat-value gold" id="st-balance">0</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">Profit</div>
                            <div class="stat-value green" id="st-profit">0 (0%)</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">Wagered</div>
                            <div class="stat-value gold" id="st-wagered-2">0</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">Bets | WR</div>
                            <div class="stat-value" id="st-bets" style="color:var(--text-light);">0 | 0%</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">Speed</div>
                            <div class="stat-value" id="st-speed" style="color:var(--text-light);">0 b/s</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">Max DD</div>
                            <div class="stat-value red" id="st-maxdd">0%</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">Status</div>
                            <div class="stat-value gold" id="st-chance">⚡ 99.98%</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">Session #</div>
                            <div class="stat-value" id="st-session-num" style="color:var(--text-light);">1</div>
                        </div>
                    </div>
                    
                    <!-- LOGS -->
                    <div style="margin-top:4px;">
                        <div style="display:flex;justify-content:space-between;font-size:9px;color:var(--text-light);margin-bottom:4px;">
                            <span>📋 RECENT BETS</span>
                            <span>Max Logs: 20</span>
                        </div>
                        <div class="logs-container" id="p-logs">
                            <div style="text-align:center;padding:20px;color:var(--text-light);font-size:10px;">
                                ⭐ ORION ASCEND v4.0<br>
                                "Fire & Forget Wager Farming"<br><br>
                                🔥 Burn for wager, recover with precision<br><br>
                                🔄 Infinite Split Recovery (Cycle 8)<br>
                                🛡️ Auto Cutloss Protection<br>
                                ⚡ Lightweight & Fast<br>
                                🚀 BOOSTER MODE<br>
                                🃏 BACCARAT D'ALEMBERT RECOVERY
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- TAB SETTINGS -->
                <div id="tab-settings" class="tab-content">
                    <div class="stats-block" style="margin-top:0px;">
                        <div style="font-weight:700;color:var(--accent);margin-bottom:8px;font-size:11px;">📌 NORMAL MODE</div>
                        <div class="grid-2">
                            <div class="md-field"><label>🎲 NORMAL CHANCE (%)</label><input type="number" id="p-normal-chance" value="99.98" step="0.01" min="1" max="99.98"></div>
                            <div class="md-field"><label>💰 NORMAL BET (% balance)</label><input type="number" id="p-basebet-normal" value="0.5" step="0.001" min="0.01" max="10"></div>
                        </div>
                    </div>
                    <div class="stats-block">
                        <div style="font-weight:700;color:var(--accent);margin-bottom:8px;font-size:11px;">🔍 VIRTUAL HUNTING</div>
                        <div class="grid-2">
                            <div class="md-field"><label>📉 MIN CHANCE (%)</label><input type="number" id="p-virt-min" value="90" step="0.5" min="1" max="90"></div>
                            <div class="md-field"><label>📈 MAX CHANCE (%)</label><input type="number" id="p-virt-max" value="95" step="0.5" min="2" max="99.98"></div>
                        </div>
                        <div style="font-size:8px;color:var(--text-light);margin-top:4px;text-align:right;" id="virt-range-info">Virtual chances: 90% - 95% (11 chances)</div>
                    </div>
                    <div class="stats-block">
                        <div style="font-weight:700;color:var(--accent);margin-bottom:8px;font-size:11px;">🌾 HARVEST & RECOVERY</div>
                        <div class="grid-2">
                            <div class="md-field"><label>🎯 HARVEST TRIGGER (× payout)</label><input type="number" id="p-harvest-trigger" value="1" step="0.5" min="1" max="20"></div>
                            <div class="md-field"><label>🔁 MAX SPLIT PER CYCLE</label><input type="number" id="p-recovery-max-splits" value="4" step="1" min="1" max="50"></div>
                        </div>
                        <div class="grid-2">
                            <div class="md-field"><label>✂️ CUTLOSS MULTIPLIER (Recovery)</label><input type="number" id="p-recovery-cutloss-multiplier" value="2" step="0.5" min="2" max="50"></div>
                            <div class="md-field"><label>📉 MIN CHANCE (Recovery)</label><input type="number" id="p-recovery-min-chance" value="77" step="0.5" min="0.01" max="99"></div>
                        </div>
                        <div class="grid-2">
                            <div class="md-field"><label>🎯 RECOVERY TARGET</label><select id="p-recovery-target"><option value="start" selected>START BALANCE</option><option value="peak">PEAK BALANCE</option></select></div>
                            <div class="md-field"><label>🔄 RECOVERY MODE</label><select id="p-recovery-mode"><option value="static" selected>STATIC</option><option value="dynamic">DYNAMIC</option></select></div>
                        </div>
                        <div class="grid-2">
                            <div class="md-field"><label>BEP SPLIT (0 = OFF)</label><input type="number" id="p-bep-split" value="0" step="1" min="0" max="20"></div>
                            <div class="md-field"><label>PEAK SPLIT (0 = OFF)</label><input type="number" id="p-peak-split" value="0" step="1" min="0" max="20"></div>
                        </div>
                    </div>
                    <div class="stats-block">
                        <div style="font-weight:700;color:var(--accent);margin-bottom:8px;font-size:11px;">🎯 WAGER FARMING</div>
                        <div class="grid-2">
                            <div class="md-field"><label>📊 TOTAL WAGER TARGET</label><input type="number" id="p-wager-total-target" value="10000" step="100" min="1" max="999999999"></div>
                            <div class="md-field"><label>📊 SESI MULTIPLIER (× balance)</label><input type="number" id="p-wager-sesi-multiplier" value="2" step="0.5" min="0.5" max="100"></div>
                        </div>
                        <div class="grid-2">
                            <div class="md-field"><label>📉 LOSS TOLERANCE (%)</label><input type="number" id="p-wager-loss-tolerance" value="0.5" step="0.01" min="0.01" max="10"></div>
                        </div>
                    </div>
                    <div class="stats-block">
                        <div style="font-weight:700;color:var(--accent);margin-bottom:8px;font-size:11px;">⚡ JIT (BURST) MODE</div>
                        <div class="grid-2">
                            <div class="md-field"><label>⚡ JIT EVERY N BET</label><input type="number" id="p-burst-every" value="20" step="1" min="0" max="100"></div>
                            <div class="md-field"><label>🎲 MIN CHANCE (%)</label><input type="number" id="p-burst-min" value="90" step="0.5" min="1" max="99"></div>
                        </div>
                        <div class="grid-2">
                            <div class="md-field"><label>🎲 MAX CHANCE (%)</label><input type="number" id="p-burst-max" value="98" step="0.5" min="2" max="99.98"></div>
                            <div class="md-field"><label>💰 BET MULTIPLIER (× loss)</label><input type="number" id="p-burst-multiplier" value="1.0" step="0.1" min="0.1" max="5"></div>
                        </div>
                        <div class="grid-2">
                            <div class="md-field"><label>💰 JIT MAX BET (%)</label><input type="number" id="p-jit-max-bet" value="5" step="0.5" min="0.5" max="20"></div>
                            <div class="md-field"><label>⚡ JIT ENABLED</label><select id="p-jit-enabled"><option value="true" selected>ENABLED</option><option value="false">DISABLED</option></select></div>
                        </div>
                        <div id="burstDisplay" style="background:var(--bg);padding:4px 8px;border-radius:6px;margin-top:6px;font-size:9px;border:1px solid var(--border);">⚡ JIT: OFF</div>
                    </div>
                    <div class="stats-block">
                        <div style="font-weight:700;color:var(--accent);margin-bottom:8px;font-size:11px;">🃏 BACCARAT RECOVERY (D'ALEMBERT)</div>
                        <div class="grid-2">
                            <div class="md-field"><label>📉 TRIGGER LOSS (%)</label><input type="number" id="p-baccarat-trigger" value="1" step="0.5" min="0.5" max="10"></div>
                            <div class="md-field"><label>💰 BASE BET (% balance)</label><input type="number" id="p-baccarat-basebet" value="0.1" step="0.05" min="0.05" max="2"></div>
                        </div>
                        <div class="grid-2">
                            <div class="md-field"><label>🔒 ENABLED</label><select id="p-baccarat-enabled"><option value="true" selected>ENABLED</option><option value="false">DISABLED</option></select></div>
                        </div>
                        <div style="font-size:8px;color:var(--text-light);margin-top:4px;text-align:center;">
                            🃏 D'Alembert: Naik 1 unit saat kalah, turun 1 unit saat menang<br>
                            🎯 Exit saat balance ≥ Sesi Start Balance
                        </div>
                    </div>
                    <div class="stats-block">
                        <div style="font-weight:700;color:var(--accent);margin-bottom:8px;font-size:11px;">💰 PROFIT TARGET & STOP LOSS</div>
                        <div class="grid-2">
                            <div class="md-field"><label>🎯 TARGET (Session %)</label><input type="number" id="p-target-pct" value="5" step="0.5"></div>
                            <div class="md-field"><label>🛑 STOP LOSS (Session %)</label><input type="number" id="p-stop-pct" value="100" step="0.5"></div>
                        </div>
                        <div class="grid-2">
                            <div class="md-field"><label>🎯 TARGET (Daily %)</label><input type="number" id="p-daily-target" value="25" step="1"></div>
                            <div class="md-field"><label>🛑 STOP LOSS (Daily %)</label><input type="number" id="p-daily-stoploss" value="100" step="1"></div>
                        </div>
                        <div class="grid-2">
                            <div class="md-field"><label>📋 SESSION TOTAL</label><input type="number" id="p-session-total" value="8" step="1"></div>
                            <div class="md-field"><label>💀 MAX BET CAP</label><input type="number" id="p-max-cap" value="0" step="0.001"></div>
                        </div>
                    </div>
                    <div class="stats-block">
                        <div style="font-weight:700;color:var(--accent);margin-bottom:8px;font-size:11px;">✂️ CUT LOSS SETTINGS</div>
                        <div class="grid-2">
                            <div class="md-field"><label>📌 CUT LOSS METHOD</label><select id="p-cut-method"><option value="static" selected>STATIC</option><option value="dynamic">DYNAMIC</option><option value="drawdown">DRAWDOWN %</option></select></div>
                            <div class="md-field"><label>🔢 BATAS MULTIPLIER (× payout)</label><input type="number" id="p-cut-multiplier" value="5" step="0.5" min="1" max="20"></div>
                        </div>
                        <div class="grid-2">
                            <div class="md-field"><label>📉 DYNAMIC MIN</label><input type="number" id="p-cut-min" value="3" step="0.5" min="0.5" max="5"></div>
                            <div class="md-field"><label>📈 DYNAMIC MAX</label><input type="number" id="p-cut-max" value="5" step="0.5" min="1" max="10"></div>
                        </div>
                        <div class="grid-2">
                            <div class="md-field"><label>📊 MAX DRAWDOWN (%)</label><input type="number" id="p-max-drawdown" value="50" step="0.5" min="1" max="100"></div>
                            <div class="md-field"><label>📋 MAX LOGS</label><input type="number" id="p-max-logs" value="20" step="5" min="10" max="100"></div>
                        </div>
                    </div>
                    <div style="font-size:8px;color:var(--text-light);text-align:center;padding:4px;border-top:1px solid var(--border);margin-top:4px;">
                        ⚡ Fire & Forget: ON (Parallel 2) · Version 4.0 · 🃏 Baccarat Recovery
                    </div>
                </div>
                
                <!-- TAB HUNT -->
                <div id="tab-hunt" class="tab-content">
                    <div style="font-weight:700;color:var(--accent);font-size:12px;margin-bottom:8px;">🎯 VIRTUAL HUNTING COUNTER</div>
                    <div class="hunt-stats">
                        <span>🎯 NEXT TRIGGER: <strong id="huntNextTrigger" style="color:var(--accent);">—</strong></span>
                        <span>⏱️ Last Update: <strong id="huntLastUpdate" style="color:var(--text-light);">—</strong></span>
                        <span>📊 Total Chances: <strong id="huntTotalChances" style="color:var(--accent);">0</strong></span>
                    </div>
                    <div id="huntTable" class="hunt-table">
                        <div style="text-align:center;padding:20px;color:var(--text-light);font-size:11px;">No virtual chances initialized</div>
                    </div>
                    <div style="display:flex;gap:12px;justify-content:center;margin-top:10px;font-size:9px;color:var(--text-light);padding:6px;border-top:1px solid var(--border);">
                        <span>⭐ READY</span>
                        <span>🔶 NEAR</span>
                        <span>🟡 APPROACH</span>
                        <span>🟢 NORMAL</span>
                    </div>
                </div>
                
                <!-- TAB HISTORY -->
                <div id="tab-history" class="tab-content">
                    <div class="harvesting-panel">
                        <div class="harvesting-header">
                            <span>📋 HARVESTING HISTORY</span>
                            <span id="harvestingCount">0</span>
                        </div>
                        <div id="harvestingList" class="harvesting-list">
                            <div style="text-align:center;padding:20px;color:var(--text-light);font-size:10px;">📋 No harvest records yet</div>
                        </div>
                    </div>
                    <div style="display:flex;gap:12px;justify-content:center;margin-top:8px;font-size:9px;color:var(--text-light);">
                        <span>🌾 Harvest</span>
                        <span>🔄 Recovery</span>
                        <span style="color:var(--success);">✅ WIN</span>
                        <span style="color:var(--danger);">✂️ CUT LOSS</span>
                    </div>
                </div>
            </div>
        </div>`;
        
        var container = document.getElementById('BotConsole');
        if (!container) {
            var div = document.createElement('div');
            div.id = 'BotConsole';
            div.innerHTML = html;
            document.body.appendChild(div);
        } else {
            container.innerHTML = html;
        }
        
        var header = document.getElementById("botHeader");
        if (header) header.addEventListener('mousedown', dragMouseDown);
        var minimizeBtn = document.getElementById("btn-minimize");
        if (minimizeBtn) minimizeBtn.onclick = toggleMinimize;
        var themeBtn = document.getElementById("btn-theme");
        if (themeBtn) themeBtn.onclick = toggleDarkMode;
        
        var savedToken = getAuthToken();
        if (savedToken) {
            var tokenEl = document.getElementById("p-token");
            if (tokenEl) tokenEl.value = savedToken;
        }
        
        // ==================== EVENT BINDINGS ====================
        
        // Max Logs
        var maxLogsEl = document.getElementById("p-max-logs");
        if (maxLogsEl) {
            maxLogsEl.onchange = function(e) {
                bot.maxLogs = Math.max(10, Math.min(100, parseInt(e.target.value) || 20));
            };
        }
        
        // Baccarat Recovery Events
        var baccaratTriggerEl = document.getElementById("p-baccarat-trigger");
        if (baccaratTriggerEl) {
            baccaratTriggerEl.onchange = function(e) {
                bot.baccaratTriggerPct = Math.min(10, Math.max(0.5, parseFloat(e.target.value) || 1));
            };
        }
        var baccaratBaseBetEl = document.getElementById("p-baccarat-basebet");
        if (baccaratBaseBetEl) {
            baccaratBaseBetEl.onchange = function(e) {
                bot.baccaratBaseBetPct = Math.min(2, Math.max(0.05, parseFloat(e.target.value) || 0.1));
            };
        }
        var baccaratEnabledEl = document.getElementById("p-baccarat-enabled");
        if (baccaratEnabledEl) {
            baccaratEnabledEl.onchange = function(e) {
                bot.baccaratEnabled = e.target.value === 'true';
            };
        }
        
        // JIT
        function updateBurstDisplayUI() {
            var container = document.getElementById("burstDisplay");
            if (!container) return;
            var isActive = bot.wagerJitEnabled && bot.burstEveryN > 0 && !bot.isBoosterMode && !baccaratRecovery.active;
            var counterText = isActive ? (bot.burstCounter + 1) + '/' + bot.burstEveryN : 'OFF';
            var isBurst = isActive && bot.burstCounter >= bot.burstEveryN;
            var chanceText = isActive ? bot.burstMinChance + '%-' + bot.burstMaxChance + '%' : '-';
            var multText = isActive ? bot.burstMultiplier.toFixed(1) + '×' : '-';
            container.innerHTML = 
                "<div style=\"display:flex;justify-content:space-between;flex-wrap:wrap;gap:4px;font-size:9px;padding:4px 6px;\">" +
                    "<span>⚡ JIT: <strong>" + (isActive ? 'ON' : 'OFF') + "</strong></span>" +
                    "<span>🔄 Counter: <strong>" + counterText + "</strong></span>" +
                    "<span>🎲 Chance: <strong>" + chanceText + "</strong></span>" +
                    "<span>💰 Mult: <strong>" + multText + "</strong></span>" +
                    "<span>🔒 Max Bet: <strong>" + bot.jitMaxBetPercent + "%</strong></span>" +
                    "<span style=\"color:" + (isBurst ? 'var(--accent)' : 'var(--text-light)') + ";\">" + (isBurst ? '⭐ JIT ACTIVE' : 'Normal bet') + "</span>" +
                "</div>";
        }
        
        function updateWagerDisplayUI() {
            var container = document.getElementById("wagerDisplay");
            if (!container) return;
            var currentBalance = bot.stats.currentBal || 0;
            var lossTolerance = (bot.wagerLossTolerancePercent / 100) * currentBalance;
            var sesiTarget = bot.wagerSesiMultiplier * currentBalance;
            var progress = bot.wagerTotalTarget > 0 ? (bot.wagerTotalAccumulated / bot.wagerTotalTarget) * 100 : 0;
            if (progress > 100) progress = 100;
            var statusText = "NORMAL";
            if (baccaratRecovery.active) {
                statusText = "🃏 BACCARAT RECOVERY";
            } else if (bot.isBoosterMode) {
                statusText = "🚀 BOOSTER";
            } else if (bot.isHarvesting) {
                statusText = bot.isRecoveryMode ? "🔄 RECOVERY" : "🌾 HARVEST";
            }
            var recoveryInfo = "";
            if (baccaratRecovery.active) {
                recoveryInfo = "<div style=\"margin-top:4px;font-size:8px;color:#8899aa;text-align:center;\">🃏 Bet: " + baccaratRecovery.currentBet.toFixed(4) + " | Side: " + baccaratRecovery.side.toUpperCase() + " | Profit: " + baccaratRecovery.profit.toFixed(4) + " | Unit: " + baccaratRecovery.unit.toFixed(4) + " | Target: " + bot.wagerSesiStartBal.toFixed(4) + "</div>";
            }
            container.innerHTML = 
                "<div style=\"display:flex;justify-content:space-between;flex-wrap:wrap;gap:4px;font-size:10px;padding:6px 10px;background:var(--bg);border-radius:8px;border:1px solid var(--border);\">" +
                    "<span>📊 Total: <strong style=\"color:var(--accent);\">" + bot.wagerTotalAccumulated.toFixed(2) + "</strong> / " + bot.wagerTotalTarget + "</span>" +
                    "<span>📋 Sesi: <strong style=\"color:var(--accent);\">" + bot.wagerSesiCounter.toFixed(2) + "</strong> / " + sesiTarget.toFixed(2) + "</span>" +
                    "<span>📉 Loss: <strong style=\"color:" + (bot.wagerSesiProfit >= 0 ? 'var(--success)' : 'var(--danger)') + ";\">" + bot.wagerSesiProfit.toFixed(4) + "</strong> / " + lossTolerance.toFixed(4) + "</span>" +
                    "<span>📈 Progress: <strong style=\"color:var(--accent);\">" + progress.toFixed(1) + "%</strong></span>" +
                    "<span style=\"color:" + (baccaratRecovery.active ? '#ff6b81' : (bot.wagerStop ? 'var(--danger)' : 'var(--success)')) + ";\">" + statusText + "</span>" +
                "</div>" +
                "<div class=\"progress-bar\" style=\"margin-top:4px;height:6px;\">" +
                    "<div class=\"progress-fill\" style=\"width:" + progress + "%;background:" + (progress >= 100 ? 'var(--danger)' : 'var(--accent)') + ";\"></div>" +
                "</div>" +
                recoveryInfo;
        }
        
        var burstEveryEl = document.getElementById("p-burst-every");
        if (burstEveryEl) burstEveryEl.onchange = function(e) {
            bot.burstEveryN = Math.min(100, Math.max(0, parseInt(e.target.value) || 0));
            bot.burstCounter = 0;
            updateBurstDisplayUI();
        };
        var burstMinEl = document.getElementById("p-burst-min");
        if (burstMinEl) burstMinEl.onchange = function(e) {
            bot.burstMinChance = Math.min(99, Math.max(1, parseFloat(e.target.value) || 1));
            if (bot.burstMinChance >= bot.burstMaxChance) bot.burstMinChance = bot.burstMaxChance - 0.5;
            updateBurstDisplayUI();
        };
        var burstMaxEl = document.getElementById("p-burst-max");
        if (burstMaxEl) burstMaxEl.onchange = function(e) {
            bot.burstMaxChance = Math.min(99.98, Math.max(2, parseFloat(e.target.value) || 98));
            if (bot.burstMaxChance <= bot.burstMinChance) bot.burstMaxChance = bot.burstMinChance + 0.5;
            updateBurstDisplayUI();
        };
        var burstMultEl = document.getElementById("p-burst-multiplier");
        if (burstMultEl) burstMultEl.onchange = function(e) {
            bot.burstMultiplier = Math.min(5, Math.max(0.1, parseFloat(e.target.value) || 1.0));
            updateBurstDisplayUI();
        };
        var jitMaxBetEl = document.getElementById("p-jit-max-bet");
        if (jitMaxBetEl) jitMaxBetEl.onchange = function(e) {
            bot.jitMaxBetPercent = Math.min(20, Math.max(0.5, parseFloat(e.target.value) || 5));
            updateBurstDisplayUI();
        };
        var jitEnabledEl = document.getElementById("p-jit-enabled");
        if (jitEnabledEl) jitEnabledEl.onchange = function(e) {
            bot.wagerJitEnabled = e.target.value === 'true';
            updateBurstDisplayUI();
        };
        
        var wagerTotalTargetEl = document.getElementById("p-wager-total-target");
        if (wagerTotalTargetEl) wagerTotalTargetEl.onchange = function(e) {
            bot.wagerTotalTarget = Math.max(1, parseFloat(e.target.value) || 10000);
            var display = document.getElementById("st-wager-total");
            if (display) display.textContent = bot.wagerTotalTarget;
            updateWagerDisplayUI();
        };
        var wagerSesiMultiplierEl = document.getElementById("p-wager-sesi-multiplier");
        if (wagerSesiMultiplierEl) wagerSesiMultiplierEl.onchange = function(e) {
            bot.wagerSesiMultiplier = Math.max(0.5, Math.min(100, parseFloat(e.target.value) || 2));
            updateWagerDisplayUI();
        };
        var wagerLossToleranceEl = document.getElementById("p-wager-loss-tolerance");
        if (wagerLossToleranceEl) wagerLossToleranceEl.onchange = function(e) {
            bot.wagerLossTolerancePercent = Math.max(0.01, Math.min(10, parseFloat(e.target.value) || 0.5));
            updateWagerDisplayUI();
        };
        
        var harvestTriggerEl = document.getElementById("p-harvest-trigger");
        if (harvestTriggerEl) harvestTriggerEl.onchange = function(e) {
            bot.harvestTrigger = Math.min(20, Math.max(1, parseFloat(e.target.value) || 1));
            initMemory();
            updateHuntTab();
        };
        
        var recoveryMaxSplitsEl = document.getElementById("p-recovery-max-splits");
        if (recoveryMaxSplitsEl) recoveryMaxSplitsEl.onchange = function(e) {
            bot.recoveryMaxSplits = Math.min(50, Math.max(1, parseInt(e.target.value) || 4));
        };
        var recoveryCutlossMultEl = document.getElementById("p-recovery-cutloss-multiplier");
        if (recoveryCutlossMultEl) recoveryCutlossMultEl.onchange = function(e) {
            bot.recoveryCutlossMultiplier = Math.min(50, Math.max(2, parseFloat(e.target.value) || 2));
        };
        var recoveryMinChanceEl = document.getElementById("p-recovery-min-chance");
        if (recoveryMinChanceEl) recoveryMinChanceEl.onchange = function(e) {
            bot.recoveryChanceMin = Math.min(99, Math.max(0.01, parseFloat(e.target.value) || 77));
        };
        
        var demoEl = document.getElementById("p-demo-toggle");
        if (demoEl) demoEl.onchange = function(e) { bot.isDemo = e.target.checked; };
        
        var normalChanceEl = document.getElementById("p-normal-chance");
        if (normalChanceEl) normalChanceEl.onchange = function(e) {
            var newChance = parseFloat(e.target.value);
            if (newChance >= 1 && newChance <= 99.98) {
                bot.normalChance = newChance;
                initVirtualChances();
                initMemory();
                updateHuntTab();
            }
        };
        var baseBetNormalEl = document.getElementById("p-basebet-normal");
        if (baseBetNormalEl) baseBetNormalEl.onchange = function(e) {
            var newPct = parseFloat(e.target.value);
            if (newPct >= 0.01 && newPct <= 10) bot.baseBetPercent = newPct;
        };
        var virtMinEl = document.getElementById("p-virt-min");
        if (virtMinEl) virtMinEl.onchange = function(e) {
            var newMin = parseFloat(e.target.value);
            if (newMin >= 1 && newMin < bot.virtMaxChance) {
                bot.virtMinChance = newMin;
                initVirtualChances();
                initMemory();
                updateHuntTab();
            }
        };
        var virtMaxEl = document.getElementById("p-virt-max");
        if (virtMaxEl) virtMaxEl.onchange = function(e) {
            var newMax = parseFloat(e.target.value);
            if (newMax > bot.virtMinChance && newMax <= 99.98) {
                bot.virtMaxChance = newMax;
                initVirtualChances();
                initMemory();
                updateHuntTab();
            }
        };
        
        var recoveryTargetEl = document.getElementById("p-recovery-target");
        if (recoveryTargetEl) recoveryTargetEl.onchange = function(e) { bot.recoveryTarget = e.target.value; };
        var recoveryModeEl = document.getElementById("p-recovery-mode");
        if (recoveryModeEl) recoveryModeEl.onchange = function(e) { bot.recoveryMode = e.target.value; };
        var bepSplitEl = document.getElementById("p-bep-split");
        if (bepSplitEl) bepSplitEl.onchange = function(e) { bot.bepSplit = Math.min(20, Math.max(0, parseInt(e.target.value) || 0)); };
        var peakSplitEl = document.getElementById("p-peak-split");
        if (peakSplitEl) peakSplitEl.onchange = function(e) { bot.peakSplit = Math.min(20, Math.max(0, parseInt(e.target.value) || 0)); };
        
        var cutMethodEl = document.getElementById("p-cut-method");
        if (cutMethodEl) cutMethodEl.onchange = function(e) { bot.cutMethod = e.target.value; };
        var cutMultEl = document.getElementById("p-cut-multiplier");
        if (cutMultEl) cutMultEl.onchange = function(e) { bot.maxCutLossMultiplier = parseFloat(e.target.value) || 5; };
        var cutMinEl = document.getElementById("p-cut-min");
        if (cutMinEl) cutMinEl.onchange = function(e) { bot.cutMinMultiplier = parseFloat(e.target.value) || 3; };
        var cutMaxEl = document.getElementById("p-cut-max");
        if (cutMaxEl) cutMaxEl.onchange = function(e) { bot.cutMaxMultiplier = parseFloat(e.target.value) || 5; };
        var maxDrawdownEl = document.getElementById("p-max-drawdown");
        if (maxDrawdownEl) maxDrawdownEl.onchange = function(e) { bot.maxDrawdownPct = parseFloat(e.target.value) || 50; };
        
        var targetPctEl = document.getElementById("p-target-pct");
        if (targetPctEl) targetPctEl.onchange = function(e) { bot.targetPct = parseFloat(e.target.value) || 5; };
        var stopPctEl = document.getElementById("p-stop-pct");
        if (stopPctEl) stopPctEl.onchange = function(e) { bot.stopLossPct = parseFloat(e.target.value) || 100; };
        var dailyTargetEl = document.getElementById("p-daily-target");
        if (dailyTargetEl) dailyTargetEl.onchange = function(e) { bot.dailyTargetPct = parseFloat(e.target.value) || 25; };
        var dailyStopEl = document.getElementById("p-daily-stoploss");
        if (dailyStopEl) dailyStopEl.onchange = function(e) { bot.dailyStopLossPct = parseFloat(e.target.value) || 100; };
        var sessionTotalEl = document.getElementById("p-session-total");
        if (sessionTotalEl) sessionTotalEl.onchange = function(e) { bot.sessionTotal = parseInt(e.target.value) || 8; };
        var maxCapEl = document.getElementById("p-max-cap");
        if (maxCapEl) maxCapEl.onchange = function(e) { bot.maxBetCap = parseFloat(e.target.value) || 0; };
        
        var loginBtn = document.getElementById("p-login");
        if (loginBtn) {
            loginBtn.onclick = async function() {
                var tokenEl = document.getElementById("p-token");
                if (!tokenEl) return;
                var token = tokenEl.value.trim();
                if (!token || token.length < 30) return;
                saveToken(token);
                var success = await syncUserInfo();
                if (success) {
                    var startBtn = document.getElementById("p-start");
                    if (startBtn) startBtn.disabled = false;
                    await updateFiatRatesOnce();
                    updateStatsDisplay();
                    sendTelegramMessage("⭐ ORION ASCEND v4.0\n\"Fire & Forget Wager Farming\"\n✅ LOGIN SUCCESS\nUser: " + bot.stakeUser);
                }
            };
        }
        var refreshBtn = document.getElementById("p-refresh");
        if (refreshBtn) {
            refreshBtn.onclick = async function() {
                if (!accessToken) return;
                await syncUserInfo();
                await updateFiatRatesOnce();
                updateStatsDisplay();
            };
        }
        
        var startBtn = document.getElementById("p-start");
        if (startBtn) {
            startBtn.onclick = async function() {
                if (bot.isPaused) {
                    bot.isPaused = false;
                    bot.isRunning = true;
                    togglePauseButton(false);
                    runLoop();
                    return;
                }
                if (bot.isRunning) return;
                
                fullReset();
                
                bot.dirtyBalance = safeGetFloat("p-dirty-bal", 50);
                bot.normalChance = safeGetFloat("p-normal-chance", 99.98);
                bot.baseBetPercent = safeGetFloat("p-basebet-normal", 0.5);
                bot.virtMinChance = safeGetFloat("p-virt-min", 90);
                bot.virtMaxChance = safeGetFloat("p-virt-max", 95);
                bot.targetPct = safeGetFloat("p-target-pct", 5);
                bot.stopLossPct = safeGetFloat("p-stop-pct", 100);
                bot.dailyTargetPct = safeGetFloat("p-daily-target", 25);
                bot.dailyStopLossPct = safeGetFloat("p-daily-stoploss", 100);
                bot.sessionTotal = safeGetInt("p-session-total", 8);
                bot.maxBetCap = safeGetFloat("p-max-cap", 0);
                bot.maxLogs = safeGetInt("p-max-logs", 20);
                
                bot.recoveryTarget = document.getElementById("p-recovery-target") ? document.getElementById("p-recovery-target").value : "start";
                bot.recoveryMode = document.getElementById("p-recovery-mode") ? document.getElementById("p-recovery-mode").value : "static";
                bot.bepSplit = safeGetInt("p-bep-split", 0);
                bot.peakSplit = safeGetInt("p-peak-split", 0);
                bot.cutMethod = document.getElementById("p-cut-method") ? document.getElementById("p-cut-method").value : "static";
                bot.maxCutLossMultiplier = safeGetFloat("p-cut-multiplier", 5);
                bot.cutMinMultiplier = safeGetFloat("p-cut-min", 3);
                bot.cutMaxMultiplier = safeGetFloat("p-cut-max", 5);
                bot.maxDrawdownPct = safeGetFloat("p-max-drawdown", 50);
                
                bot.baccaratEnabled = document.getElementById("p-baccarat-enabled") ? document.getElementById("p-baccarat-enabled").value === 'true' : true;
                bot.baccaratTriggerPct = safeGetFloat("p-baccarat-trigger", 1);
                bot.baccaratBaseBetPct = safeGetFloat("p-baccarat-basebet", 0.1);
                
                bot.burstEveryN = safeGetInt("p-burst-every", 20);
                bot.burstMinChance = safeGetFloat("p-burst-min", 90);
                bot.burstMaxChance = safeGetFloat("p-burst-max", 98);
                bot.burstMultiplier = safeGetFloat("p-burst-multiplier", 1.0);
                bot.jitMaxBetPercent = safeGetFloat("p-jit-max-bet", 5);
                bot.burstCounter = 0;
                var jitEnabledEl2 = document.getElementById("p-jit-enabled");
                bot.wagerJitEnabled = jitEnabledEl2 ? jitEnabledEl2.value === 'true' : true;
                
                bot.wagerTotalTarget = safeGetFloat("p-wager-total-target", 10000);
                bot.wagerSesiMultiplier = safeGetFloat("p-wager-sesi-multiplier", 2);
                bot.wagerLossTolerancePercent = safeGetFloat("p-wager-loss-tolerance", 0.5);
                bot.wagerTotalAccumulated = 0;
                bot.wagerSesiCounter = 0;
                bot.wagerSesiStartBal = 0;
                bot.wagerSesiProfit = 0;
                bot.wagerStop = false;
                bot.wagerWaitingForTrigger = false;
                
                bot.recoveryMaxSplits = safeGetInt("p-recovery-max-splits", 4);
                bot.recoveryCutlossMultiplier = safeGetFloat("p-recovery-cutloss-multiplier", 2);
                bot.recoveryChanceMin = safeGetFloat("p-recovery-min-chance", 77);
                bot.recoverySplitCounter = 0;
                
                bot.harvestTrigger = safeGetFloat("p-harvest-trigger", 1);
                bot.harvestTrigger = Math.min(20, Math.max(1, bot.harvestTrigger));
                
                await updateFiatRatesOnce();
                
                if (bot.fiatRates.idr > 0) {
                    bot.minBet = bot.minBetIdr / bot.fiatRates.idr;
                    if (bot.minBet < 0.00000001) bot.minBet = 0.00000001;
                } else bot.minBet = 0.0014;
                
                var balance = bot.isDemo ? bot.dirtyBalance : bot.realBalance;
                if (!bot.isDemo && balance === 0) return;
                
                startBalanceValue = balance;
                originalSessionStartBalance = balance;
                peakBalanceEver = balance;
                recoveryStartBalance = 0;
                bot.wagerSesiStartBal = balance;
                
                bot.dailyStartBalance = balance;
                bot.dailyProfit = 0;
                bot.dailyTargetReached = false;
                bot.lastDailyReset = new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate(), 0, 0, 0).getTime();
                bot.stats = { profit: 0, wagered: 0, startBal: balance, currentBal: balance, bets: 0, wins: 0, loss: 0, ties: 0, startTime: Date.now(), maxDD: 0, maxBet: 0, maxDrawdownPct: 0, peakBalance: balance };
                bot.betTimestamps = [];
                bot.startTime = Date.now();
                bot.sessionStartTime = new Date();
                bot.isHarvesting = false;
                bot.isRecoveryMode = false;
                bot.isAfterRecovery = false;
                bot.recoveryStep = 0;
                bot.harvestCount = 0;
                bot.harvestBet = 0;
                bot.lastBetAmount = 0;
                bot.sessionProfit = 0;
                bot.totalWager = 0;
                bot.highestProfit = 0;
                bot.maxDrawdownVal = 0;
                bot.balanceStartSnapshot = balance;
                bot.isRunning = true;
                bot.isPaused = false;
                bot.isSleeping = false;
                bot.lastTGReport = Date.now();
                bot.lastFiatUpdate = 0;
                bot.isResetting = false;
                bot.resetCountdownRemaining = 0;
                bot.worstDrawdown = 0;
                bot.worstDrawdownChance = 0;
                bot.worstDrawdownLS = 0;
                bot.worstBet = 0;
                bot.sessionNumber = 1;
                bot.sessionsCompleted = 0;
                bot.recovery = null;
                bot.isBoosterMode = false;
                bot.boosterStartProfit = 0;
                bot.boosterBetAmount = 0;
                baccaratRecovery.active = false;
                baccaratRecovery.startBalance = 0;
                baccaratRecovery.baseBet = 0;
                baccaratRecovery.currentBet = 0;
                baccaratRecovery.unit = 0;
                baccaratRecovery.profit = 0;
                baccaratRecovery.consecutiveLoss = 0;
                baccaratRecovery.wins = 0;
                baccaratRecovery.losses = 0;
                baccaratRecovery.ties = 0;
                baccaratRecovery.totalBets = 0;
                boosterChanceIndex = 0;
                diceInFlight = 0;
                pendingDiceMeta = [];
                isResting = false;
                normalCycleStartTime = 0;
                harvestingEntries = [];
                profitHistory = [];
                
                initVirtualChances();
                initMemory();
                
                toggleStartStop(true);
                togglePauseButton(false);
                var startBtnEl = document.getElementById("p-start");
                if (startBtnEl) startBtnEl.textContent = "START";
                
                var burstStatus = bot.wagerJitEnabled && bot.burstEveryN > 0 ? 'ON (Every ' + bot.burstEveryN + ' bet)' : 'OFF';
                var baccaratStatus = bot.baccaratEnabled ? 'ON (Trigger: ' + bot.baccaratTriggerPct + '%, Base Bet: ' + bot.baccaratBaseBetPct + '%)' : 'OFF';
                sendTelegramMessage("⭐ ORION ASCEND v4.0\n\"Fire & Forget Wager Farming\"\n🔥 STARTED\nBalance: " + balance.toFixed(2) + "\nNormal Chance: " + bot.normalChance + "%\nJIT: " + burstStatus + "\nJIT Max Bet: " + bot.jitMaxBetPercent + "%\nTotal Wager: " + bot.wagerTotalTarget + "\nSesi Multiplier: " + bot.wagerSesiMultiplier + "× balance\nLoss Tolerance: " + bot.wagerLossTolerancePercent + "%\nHarvest Trigger: " + bot.harvestTrigger + "× payout\nVirtual Range: " + bot.virtMinChance + "%-" + bot.virtMaxChance + "%\n🃏 Baccarat Recovery: " + baccaratStatus + "\n⚡ Fire & Forget: ON (Parallel " + wagerParallelCap + ")");
                
                updateBurstDisplayUI();
                updateHuntTab();
                updateWagerDisplayUI();
                runLoop();
            };
        }
        
        function pauseBot() {
            if (!bot.isRunning || bot.isPaused) return;
            bot.isPaused = true;
            bot.isRunning = false;
            togglePauseButton(true);
        }
        var pauseBtn = document.getElementById("p-pause");
        if (pauseBtn) pauseBtn.onclick = function() { if (bot.isRunning && !bot.isPaused) pauseBot(); };
        
        var stopBtn = document.getElementById("p-stop");
        if (stopBtn) stopBtn.onclick = async function() { fullReset(); await sendSessionReport(); };
        
        var resetBtn = document.getElementById("p-reset");
        if (resetBtn) resetBtn.onclick = function() { if (bot.isRunning) return; fullReset(); };
        
        var currencyEl = document.getElementById("p-currency");
        if (currencyEl) currencyEl.onchange = function() { 
            bot.selectedCurrency = document.getElementById("p-currency").value; 
            bot.fiatRateFetched = false;
            updateFiatRatesOnce();
        };
        
        setInterval(updateStatsDisplay, 1000);
        setInterval(function() {
            var huntTab = document.getElementById('tab-hunt');
            if (huntTab && huntTab.classList.contains('active')) updateHuntTab();
        }, 2000);
        
        renderHarvestingEntries();
        updateBurstDisplayUI();
        updateHuntTab();
        updateWagerDisplayUI();
        
        var wagerTotalDisplay = document.getElementById("st-wager-total");
        if (wagerTotalDisplay) wagerTotalDisplay.textContent = bot.wagerTotalTarget;
    }
    
    // ==================== INITIALIZATION ====================
    createUI();
})();
